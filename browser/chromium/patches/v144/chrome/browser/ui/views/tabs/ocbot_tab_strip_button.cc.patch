+
+#include "chrome/browser/ui/views/tabs/ocbot_tab_strip_button.h"
+
+#include "chrome/browser/ui/color/chrome_color_id.h"
+#include "chrome/browser/ui/views/tabs/tab_strip_control_button.h"
+#include "chrome/grit/chrome_unscaled_resources.h"
+#include "ui/base/cursor/cursor.h"
+#include "ui/base/metadata/metadata_impl_macros.h"
+#include "ui/base/models/image_model.h"
+#include "ui/base/resource/resource_bundle.h"
+#include "ui/color/color_id.h"
+#include "ui/gfx/canvas.h"
+#include "ui/gfx/font_list.h"
+#include "ui/gfx/text_utils.h"
+#include "ui/views/accessibility/view_accessibility.h"
+#include "ui/views/animation/ink_drop.h"
+#include "ui/views/controls/image_view.h"
+#include "ui/views/controls/label.h"
+#include "ui/views/view_class_properties.h"
+
+namespace {
+constexpr int kCapsuleHeight = 38;
+constexpr int kCapsuleCornerRadius = 19;
+constexpr int kLogoSize = 22;
+constexpr int kPaddingH = 26;
+constexpr int kImageLabelSpacing = 20;
+constexpr int kSeparatorHeight = 14;
+constexpr SkColor kLetterColor = SkColorSetRGB(0xD3, 0x38, 0xFF);
+constexpr int kLetterFontSizeDelta = 4;
+}  // namespace
+
+OcbotTabStripButton::OcbotTabStripButton(TabStripController* controller,
+                                         PressedCallback callback)
+    : TabStripControlButton(controller,
+                            std::move(callback),
+                            std::u16string(),
+                            Edge::kNone,
+                            Edge::kNone) {
+  // PNG product logo as the button image.
+  const gfx::ImageSkia* logo =
+      ui::ResourceBundle::GetSharedInstance().GetImageSkiaNamed(
+          IDR_PRODUCT_LOGO_24_SHORTCUTS);
+  if (logo) {
+    auto image_model = ui::ImageModel::FromImageSkia(*logo);
+    SetImageModel(views::Button::STATE_NORMAL, image_model);
+    SetImageModel(views::Button::STATE_HOVERED, image_model);
+    SetImageModel(views::Button::STATE_PRESSED, image_model);
+  }
+
+  // Use the built-in label() for the letter.
+  SetText(u"O");
+  label()->SetFontList(
+      gfx::FontList().DeriveWithSizeDelta(kLetterFontSizeDelta));
+  label()->SetAutoColorReadabilityEnabled(false);
+  label()->SetElideBehavior(gfx::ElideBehavior::NO_ELIDE);
+  SetEnabledTextColors(kLetterColor);
+  SetImageLabelSpacing(kImageLabelSpacing);
+
+  // Always show background.
+  set_paint_transparent_for_custom_image_theme(false);
+  SetBackgroundFrameActiveColorId(kColorNewTabButtonCRBackgroundFrameActive);
+  SetBackgroundFrameInactiveColorId(
+      kColorNewTabButtonCRBackgroundFrameInactive);
+
+  // Disable ink drop.
+  views::InkDrop::Get(this)->SetMode(views::InkDropHost::InkDropMode::OFF);
+
+  SetTooltipText(u"Ocbot AI Assistant");
+  GetViewAccessibility().SetName(u"Ocbot AI Assistant");
+}
+
+OcbotTabStripButton::~OcbotTabStripButton() = default;
+
+int OcbotTabStripButton::GetCornerRadius() const {
+  return kCapsuleCornerRadius;
+}
+
+gfx::Size OcbotTabStripButton::CalculatePreferredSize(
+    const views::SizeBounds& available_size) const {
+  int text_width = gfx::GetStringWidth(label()->GetText(),
+                                        label()->font_list());
+  int width = kPaddingH + kLogoSize + kImageLabelSpacing +
+              text_width + kPaddingH;
+  return gfx::Size(width, kCapsuleHeight);
+}
+
+void OcbotTabStripButton::PaintButtonContents(gfx::Canvas* canvas) {
+  TabStripControlButton::PaintButtonContents(canvas);
+
+  // Draw separator line between logo and letter.
+  const auto* cp = GetColorProvider();
+  SkColor sep_color = cp ? cp->GetColor(ui::kColorSysOutline)
+                         : SkColorSetA(SK_ColorGRAY, 0x80);
+  int sep_x = kPaddingH + kLogoSize + kImageLabelSpacing / 2;
+  int sep_y = (height() - kSeparatorHeight) / 2;
+  cc::PaintFlags flags;
+  flags.setColor(sep_color);
+  flags.setAntiAlias(true);
+  canvas->DrawRect(gfx::RectF(sep_x, sep_y, 1, kSeparatorHeight), flags);
+}
+
+void OcbotTabStripButton::SetPanelOpen(bool open) {
+  if (panel_open_ == open) {
+    return;
+  }
+  panel_open_ = open;
+
+  if (open) {
+    SetBackgroundFrameActiveColorId(ui::kColorSysStateHeaderHover);
+    SetBackgroundFrameInactiveColorId(ui::kColorSysStateHeaderHover);
+    SetText(u"C");
+  } else {
+    SetBackgroundFrameActiveColorId(kColorNewTabButtonCRBackgroundFrameActive);
+    SetBackgroundFrameInactiveColorId(
+        kColorNewTabButtonCRBackgroundFrameInactive);
+    SetText(u"O");
+  }
+
+  SetEnabledTextColors(kLetterColor);
+  PreferredSizeChanged();
+}
+
+void OcbotTabStripButton::NotifyClick(const ui::Event& event) {
+  SetPanelOpen(!panel_open_);
+  views::LabelButton::NotifyClick(event);
+}
+
+ui::Cursor OcbotTabStripButton::GetCursor(const ui::MouseEvent& event) {
+  return ui::Cursor(ui::mojom::CursorType::kHand);
+}
+
+void OcbotTabStripButton::UpdateColors() {
+  TabStripControlButton::UpdateColors();
+  views::InkDrop::Get(this)->SetMode(views::InkDropHost::InkDropMode::OFF);
+  // Override text color back to brand purple.
+  SetEnabledTextColors(kLetterColor);
+}
+
+BEGIN_METADATA(OcbotTabStripButton)
+END_METADATA
