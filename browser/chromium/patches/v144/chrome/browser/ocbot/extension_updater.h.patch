+#ifndef CHROME_BROWSER_OCBOT_EXTENSION_UPDATER_H_
+#define CHROME_BROWSER_OCBOT_EXTENSION_UPDATER_H_
+
+#include <memory>
+#include <optional>
+#include <string>
+
+#include "base/files/file_path.h"
+#include "base/functional/callback.h"
+#include "base/memory/weak_ptr.h"
+#include "base/timer/timer.h"
+
+namespace network {
+class SimpleURLLoader;
+namespace mojom {
+class URLLoaderFactory;
+}
+}  // namespace network
+
+namespace ocbot {
+
+// Downloads and installs ocbot extension updates.
+//
+// Workflow:
+//   1. After a startup delay, fetches latest.json from R2 CDN.
+//   2. On failure, falls back to GitHub Releases API.
+//   3. Compares the remote version against the currently loaded extension.
+//   4. If newer, downloads the zip asset and extracts to <user-data-dir>/ocbot-extension/.
+//   5. The update takes effect on next browser restart (or hot-reload if callback set).
+//
+// Subsequent checks run every 4 hours while the browser is open.
+class OcbotExtensionUpdater {
+ public:
+  OcbotExtensionUpdater();
+  ~OcbotExtensionUpdater();
+
+  OcbotExtensionUpdater(const OcbotExtensionUpdater&) = delete;
+  OcbotExtensionUpdater& operator=(const OcbotExtensionUpdater&) = delete;
+
+  // Starts the periodic update check. First check after |initial_delay|.
+  void Start();
+
+  // Sets a callback to hot-reload the extension after an OTA update.
+  // If not set, updates take effect on next browser restart.
+  using ReloadCallback = base::RepeatingClosure;
+  void SetReloadCallback(ReloadCallback callback);
+
+ private:
+  void CheckForUpdate();
+  void OnR2MetadataFetched(std::optional<std::string> response_body);
+  void CheckForUpdateFromGitHub();
+  void OnReleaseFetched(std::optional<std::string> response_body);
+  void DownloadZip(const std::string& download_url,
+                   const std::string& remote_version);
+  void OnZipDownloaded(const std::string& remote_version,
+                       base::FilePath temp_path);
+  void ReloadExtension();
+
+  std::string GetCurrentVersion() const;
+  base::FilePath GetUpdateDir() const;
+  network::mojom::URLLoaderFactory* GetURLLoaderFactory();
+
+  base::RepeatingTimer check_timer_;
+  std::unique_ptr<network::SimpleURLLoader> url_loader_;
+  ReloadCallback reload_callback_;
+
+  base::WeakPtrFactory<OcbotExtensionUpdater> weak_factory_{this};
+};
+
+}  // namespace ocbot
+
+#endif  // CHROME_BROWSER_OCBOT_EXTENSION_UPDATER_H_
