+
+#ifndef CHROME_BROWSER_OCBOT_RUNTIME_MANAGER_H_
+#define CHROME_BROWSER_OCBOT_RUNTIME_MANAGER_H_
+
+#include <string>
+
+#include "base/files/file_path.h"
+#include "base/memory/weak_ptr.h"
+#include "base/process/process.h"
+#include "base/timer/timer.h"
+#include "components/keep_alive_registry/scoped_keep_alive.h"
+
+namespace ocbot {
+
+// Manages the embedded OpenClaw runtime subprocess lifecycle.
+//
+// Responsibilities:
+//   1. Locate Node.js and OpenClaw (OTA runtime or embedded Resources/).
+//   2. Ensure a default OpenClaw config exists for Ocbot.
+//   3. On startup, apply pending OTA updates (symlink swap).
+//   4. Spawn `node openclaw.mjs gateway run` as a child process.
+//   5. Periodically health-check the gateway (every 30s).
+//   6. Auto-restart if the subprocess dies unexpectedly.
+//   7. Rollback to previous version or embedded fallback on failure.
+//   8. Gracefully terminate the subprocess on browser shutdown.
+//
+// The RuntimeManager is a singleton created during browser startup.
+// It is skipped in dev mode (--ocbot-extension-dir present).
+class RuntimeManager {
+ public:
+  RuntimeManager();
+  ~RuntimeManager();
+
+  RuntimeManager(const RuntimeManager&) = delete;
+  RuntimeManager& operator=(const RuntimeManager&) = delete;
+
+  // Starts the runtime manager. Locates binaries, generates config,
+  // spawns the gateway subprocess, and begins health checks.
+  void Start();
+
+  // Stops the gateway subprocess gracefully.
+  void Stop();
+
+  // Returns true if the gateway subprocess is currently running.
+  bool IsRunning() const;
+
+  // Returns the gateway port.
+  int GetGatewayPort() const { return kGatewayPort; }
+
+ private:
+  static constexpr int kGatewayPort = 18789;
+
+  // Locate runtime: try OTA first, then embedded Resources/.
+  bool LocateRuntime();
+
+  // Locate embedded node and openclaw in Resources/.
+  bool LocateEmbeddedRuntime();
+
+  // Ensure OpenClaw config directory and default config file exist.
+  bool EnsureConfig();
+
+  // Spawn the gateway subprocess.
+  void SpawnGateway();
+
+  // Called by health_check_timer_ periodically.
+  void HealthCheck();
+
+  // Called after health check HTTP request completes on the thread pool.
+  void OnHealthCheckComplete(bool alive);
+
+  // OTA update management.
+  bool ApplyPendingUpdate();
+  void RevertToPrevious();
+  void CleanupOldVersions();
+
+  // Get the OTA runtime root directory.
+  base::FilePath GetOtaRuntimeDir() const;
+
+  // Paths resolved at startup.
+  base::FilePath node_path_;
+  base::FilePath openclaw_dir_;
+  base::FilePath data_dir_;
+  base::FilePath config_dir_;
+  base::FilePath config_file_;
+  base::FilePath state_dir_;
+  base::FilePath workspace_dir_;
+
+  // OTA runtime state.
+  base::FilePath ota_runtime_dir_;  // <app-support>/Ocbot/runtime/
+  bool using_ota_runtime_ = false;
+  bool just_applied_update_ = false;
+
+  // The gateway child process.
+  base::Process gateway_process_;
+
+  // Health check timer (every 30 seconds).
+  base::RepeatingTimer health_check_timer_;
+
+  // Tracks consecutive health check failures for restart logic.
+  int consecutive_failures_ = 0;
+  static constexpr int kMaxFailuresBeforeRestart = 3;
+
+  // Keeps the browser process alive while the runtime is running.
+  std::unique_ptr<ScopedKeepAlive> keep_alive_;
+
+  base::WeakPtrFactory<RuntimeManager> weak_factory_{this};
+};
+
+}  // namespace ocbot
+
+#endif  // CHROME_BROWSER_OCBOT_RUNTIME_MANAGER_H_
