+
+#ifndef CHROME_BROWSER_OCBOT_OCBOT_STATUS_ICON_MAC_H_
+#define CHROME_BROWSER_OCBOT_OCBOT_STATUS_ICON_MAC_H_
+
+#include <memory>
+#include <string>
+
+#include "chrome/browser/ui/browser_list_observer.h"
+
+namespace ocbot {
+
+// macOS menu bar status icon for Ocbot.
+// Shows runtime status and provides Open/Quit actions.
+// Also observes BrowserList to show a one-time notification when all
+// windows close (informing the user that Ocbot is still running).
+class OcbotStatusIcon : public BrowserListObserver {
+ public:
+  OcbotStatusIcon();
+  ~OcbotStatusIcon() override;
+
+  OcbotStatusIcon(const OcbotStatusIcon&) = delete;
+  OcbotStatusIcon& operator=(const OcbotStatusIcon&) = delete;
+
+  enum class Status { kHealthy, kUpdating, kError };
+  void SetStatus(Status status);
+  void SetRuntimeVersion(const std::string& version);
+
+  // BrowserListObserver:
+  void OnBrowserRemoved(Browser* browser) override;
+
+  // Forward-declared; defined in .mm.
+  class Impl;
+
+ private:
+  std::unique_ptr<Impl> impl_;
+
+  Status status_ = Status::kHealthy;
+  std::string runtime_version_;
+};
+
+}  // namespace ocbot
+
+#endif  // CHROME_BROWSER_OCBOT_OCBOT_STATUS_ICON_MAC_H_
