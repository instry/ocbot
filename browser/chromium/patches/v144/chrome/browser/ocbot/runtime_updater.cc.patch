+constexpr char kR2LatestUrl[] = "https://cdn.oc.bot/latest.json";
+
+// First check 60 seconds after startup.
+constexpr base::TimeDelta kInitialDelay = base::Seconds(60);
+// Subsequent checks every 4 hours.
+constexpr base::TimeDelta kCheckInterval = base::Hours(4);
+// Max response size for latest.json (256 KB).
+constexpr int kMaxApiResponseSize = 256 * 1024;
+// Max download sizes.
+constexpr int64_t kMaxBaseLayerSize = 500LL * 1024 * 1024;  // 500 MB
+constexpr int64_t kMaxAppLayerSize = 100LL * 1024 * 1024;   // 100 MB
+
+const net::NetworkTrafficAnnotationTag kTrafficAnnotation =
+    net::DefineNetworkTrafficAnnotation("ocbot_runtime_updater", R"(
+        semantics {
+          sender: "Ocbot Runtime Updater"
+          description:
+            "Checks for OpenClaw runtime updates and downloads new versions "
+            "for application on next browser restart."
+          trigger:
+            "Periodically after browser startup (every 4 hours)."
+          data: "No user data is sent. Only fetches public release metadata."
+          destination: OTHER
+          internal {
+            contacts {
+              email: "niceboybao@gmail.com"
+            }
+          }
+          user_data {
+            type: NONE
+          }
+          last_reviewed: "2025-01-01"
+        }
+        policy {
+          cookies_allowed: NO
+          setting: "Not configurable."
+          policy_exception_justification:
+            "Essential for keeping the OpenClaw runtime up to date."
+        })");
+
+// Read a JSON file and return as dict. Returns nullopt on failure.
+std::optional<base::Value::Dict> ReadJsonFile(const base::FilePath& path) {
+  std::string content;
+  if (!base::ReadFileToString(path, &content)) {
+    return std::nullopt;
+  }
+  auto result = base::JSONReader::ReadDict(content, base::JSON_PARSE_RFC);
+  return result;
+}
+
+// Write a dict as JSON to a file.
+bool WriteJsonFile(const base::FilePath& path, const base::Value::Dict& dict) {
+  std::string json;
+  if (!base::JSONWriter::WriteWithOptions(
+          dict, base::JSONWriter::OPTIONS_PRETTY_PRINT, &json)) {
+    return false;
+  }
+  return base::WriteFile(path, json);
+}
