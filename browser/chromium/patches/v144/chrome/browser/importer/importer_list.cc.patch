+void DetectChromeProfiles(
+    std::vector<user_data_importer::SourceProfile>* profiles) {
+  base::ScopedBlockingCall scoped_blocking_call(FROM_HERE,
+                                                base::BlockingType::MAY_BLOCK);
+
+  base::FilePath user_data_path = GetChromeUserDataPath();
+  if (user_data_path.empty() || !base::DirectoryExists(user_data_path)) {
+    return;
+  }
+
+  std::vector<ChromeProfileInfo> chrome_profiles =
+      GetChromeProfiles(user_data_path);
+  if (chrome_profiles.empty()) {
+    return;
+  }
+
+  for (const auto& chrome_profile : chrome_profiles) {
+    base::FilePath profile_path = user_data_path.Append(
+        base::FilePath::FromUTF8Unsafe(chrome_profile.dir_name));
+
+    uint16_t items = user_data_importer::NONE;
+    if (!ChromeImporterCanImport(profile_path, &items)) {
+      continue;
+    }
+
+    user_data_importer::SourceProfile profile;
+    if (chrome_profiles.size() == 1) {
+      profile.importer_name =
+          l10n_util::GetStringUTF16(IDS_IMPORT_FROM_CHROME);
+    } else {
+      profile.importer_name =
+          l10n_util::GetStringUTF16(IDS_IMPORT_FROM_CHROME) + u" — " +
+          base::UTF8ToUTF16(chrome_profile.display_name);
+    }
+    profile.importer_type = user_data_importer::TYPE_CHROME;
+    profile.source_path = profile_path;
+    profile.services_supported = items;
+    profiles->push_back(profile);
+  }
+}
+
 // |locale|: The application locale used for lookups in Firefox's
 // locale-specific search engines feature (see firefox_importer.cc for
 // details).
