 String Navigator::GetAcceptLanguages() {
+  if (auto* fingerprint_manager =
+          oc_fingerprint::FingerprintManager::GetInstance()) {
+    const auto& config = fingerprint_manager->GetConfig();
+    if (config.languages_enabled.value_or(false) && config.languages.has_value() &&
+        !config.languages->empty()) {
+      StringBuilder builder;
+      for (size_t i = 0; i < config.languages->size(); ++i) {
+        if (i > 0) {
+          builder.Append(",");
+        }
+        builder.Append(String::FromUTF8(config.languages->at(i).c_str()));
+      }
+      return builder.ToString();
+    }
+  }
+
   if (!DomWindow())
     return DefaultLanguage();
 
