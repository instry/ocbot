{
  "name": "ocbot",
  "version": "2026.3.28",
  "description": "Ocbot — Your Web4 Agent",
  "private": true,
  "author": {
    "name": "MALA TECH LLC"
  },
  "main": "dist/main/index.js",
  "scripts": {
    "dev": "npm run build:main && npm run build:renderer && electron .",
    "sync:version": "node scripts/sync-version.cjs",
    "prepare:openclaw": "npm run sync:version && node scripts/electron-builder-hooks.cjs --prepare-only",
    "package:mac:x64": "node scripts/package.cjs --platform mac --arch x64",
    "package:mac:arm64": "node scripts/package.cjs --platform mac --arch arm64",
    "package:mac:all": "node scripts/package.cjs --platform mac --arch all",
    "package:win:x64": "node scripts/package.cjs --platform win --arch x64",
    "package:win:arm64": "node scripts/package.cjs --platform win --arch arm64",
    "package:win:ia32": "node scripts/package.cjs --platform win --arch ia32",
    "package:win:all": "node scripts/package.cjs --platform win --arch all",
    "package:all": "node scripts/package.cjs --platform all --arch all",
    "manifest:update": "node scripts/generate-update-manifest.cjs",
    "build": "npm run sync:version && npm run build:main && npm run build:renderer",
    "build:main": "tsc -p tsconfig.main.json && tsc -p tsconfig.preload.json",
    "build:renderer": "vite build",
    "start": "electron .",
    "pack": "npm run build && electron-builder --dir",
    "dist": "npm run build && electron-builder",
    "clean": "rm -rf dist out"
  },
  "dependencies": {
    "@larksuite/openclaw-lark-tools": "~1.0.26",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dompurify": "^3.3.3",
    "electron-updater": "^6.3.0",
    "lucide-react": "^1.7.0",
    "marked": "^17.0.5",
    "qrcode.react": "^4.2.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-markdown": "^10.1.0",
    "react-router": "^7.13.2",
    "rehype-sanitize": "^6.0.0",
    "remark-gfm": "^4.0.1",
    "tailwind-merge": "^3.5.0",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.2",
    "@types/dompurify": "^3.0.5",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "electron": "^35.0.0",
    "electron-builder": "^26.0.0",
    "tailwindcss": "^4.2.2",
    "typescript": "^5.7.0",
    "vite": "^8.0.3"
  }
}
