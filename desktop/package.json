{
  "name": "ocbot-desktop",
  "version": "0.1.0",
  "description": "Ocbot Desktop — the easiest way to use OpenClaw",
  "private": true,
  "main": "dist/main/index.js",
  "scripts": {
    "dev": "tsc -p tsconfig.main.json && tsc -p tsconfig.preload.json && electron .",
    "build": "tsc -p tsconfig.main.json && tsc -p tsconfig.preload.json",
    "start": "electron .",
    "pack": "npm run build && electron-builder --dir",
    "dist": "npm run build && electron-builder",
    "clean": "rm -rf dist out"
  },
  "dependencies": {
    "electron-updater": "^6.3.0"
  },
  "devDependencies": {
    "electron": "^35.0.0",
    "electron-builder": "^26.0.0",
    "typescript": "^5.7.0"
  }
}
