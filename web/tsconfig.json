{
  "extends": "./.wxt/tsconfig.json",
  "compilerOptions": {
    "baseUrl": ".",
    "experimentalDecorators": true,
    "useDefineForClassFields": false,
    "paths": {
      "@/*": ["./*"],
      "@openclaw-ui/*": ["../openclaw/ui/src/ui/*"]
    },
    "lib": ["ES2023", "DOM", "DOM.Iterable"]
  },
  "include": [
    "**/*.ts",
    ".wxt/**/*.ts"
  ]
}
