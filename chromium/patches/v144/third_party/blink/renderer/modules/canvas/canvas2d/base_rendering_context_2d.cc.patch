+                  for (int col = 0; col < width; ++col) {
+                    size_t pixel_offset =
+                        static_cast<size_t>(col) * bytes_per_pixel;
+                    size_t pixel_base = row_offset + pixel_offset;
+                    int64_t hash =
+                        (static_cast<int64_t>(sx + col) * 49297) +
+                        (static_cast<int64_t>(sy + row) * 9301) + 49297;
