+                    for (int k = 0; k < 3; ++k) {
+                      size_t index = pixel_base + static_cast<size_t>(k);
+                      int value = static_cast<int>(bytes[index]) + noise;
+                      if (value < 0) {
+                        value = 0;
+                      } else if (value > 255) {
+                        value = 255;
+                      }
+                      bytes[index] = static_cast<uint8_t>(value);
