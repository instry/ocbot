+          int bytes_per_pixel = pixmap.info().bytesPerPixel();
+          size_t row_bytes = pixmap.rowBytes();
+          if (width > 0 && height > 0 && bytes_per_pixel >= 3) {
+            base::CheckedNumeric<size_t> min_row_bytes = width;
+            min_row_bytes *= bytes_per_pixel;
+            if (min_row_bytes.IsValid() &&
+                row_bytes >= min_row_bytes.ValueOrDie()) {
+              base::span<uint8_t> bytes = image_data->RawByteSpan();
+              base::CheckedNumeric<size_t> total_bytes = row_bytes;
+              total_bytes *= height;
+              if (total_bytes.IsValid() &&
+                  bytes.size() >= total_bytes.ValueOrDie()) {
+                for (int row = 0; row < height; ++row) {
+                  size_t row_offset =
