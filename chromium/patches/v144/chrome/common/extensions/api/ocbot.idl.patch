+// Copyright 2025 The Ocbot Authors
+// SPDX-License-Identifier: MIT
+
+// Use the <code>chrome.ocbot</code> API to configure OpenClaw from the
+// browser extension.
+namespace ocbot {
+  dictionary OpenClawProvider {
+    DOMString providerId;
+    DOMString baseUrl;
+    DOMString apiFormat;
+    DOMString apiKey;
+    DOMString modelId;
+    DOMString modelName;
+    long contextWindow;
+    long maxTokens;
+  };
+
+  dictionary OpenClawConfig {
+    DOMString? gatewayUrl;
+    boolean running;
+  };
+
+  callback SetProviderCallback = void(boolean success);
+  callback GetConfigCallback = void(OpenClawConfig config);
+
+  interface Functions {
+    // Write an LLM provider configuration to openclaw.json.
+    static void setProvider(OpenClawProvider provider,
+                            SetProviderCallback callback);
+
+    // Read the current OpenClaw configuration state.
+    static void getConfig(GetConfigCallback callback);
+  };
+};
