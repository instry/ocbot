+// Copyright 2025 The Chromium Authors
+// Use of this source code is governed by a BSD-style license that can be
+// found in the LICENSE file.
+
+// API for native macOS desktop control — mouse, keyboard, apps, accessibility
+// tree, screenshots, shell commands, and AppleScript.
+[implemented_in="chrome/browser/extensions/api/ocbot/ocbot_api.h"]
+namespace ocbot {
+
+  dictionary PermissionStatus {
+    boolean supported;
+    boolean? accessibility;
+    boolean? screenRecording;
+  };
+
+  dictionary AppInfo {
+    DOMString name;
+    long pid;
+    DOMString bundleId;
+    boolean frontmost;
+  };
+
+  dictionary CommandResult {
+    DOMString stdout;
+    DOMString stderr;
+    long exitCode;
+  };
+
+  dictionary AppleScriptResult {
+    DOMString result;
+  };
+
+  dictionary FileEntry {
+    DOMString name;
+    DOMString type;
+    double size;
+  };
+
+  dictionary TreeNode {
+    long nodeId;
+    DOMString role;
+    DOMString? name;
+    DOMString? value;
+    long? x;
+    long? y;
+    long? width;
+    long? height;
+    TreeNode[]? children;
+  };
+
+  dictionary DesktopTree {
+    DOMString appName;
+    long pid;
+    TreeNode root;
+  };
+
+  dictionary ClipboardContent {
+    DOMString text;
+  };
+
+  dictionary ScreenshotResult {
+    DOMString dataUrl;
+    long width;
+    long height;
+  };
+
+  callback PermissionStatusCallback = void(PermissionStatus status);
+  callback VoidCallback = void();
+  callback ScreenshotCallback = void(ScreenshotResult result);
+  callback ClickCallback = void();
+  callback TypeCallback = void();
+  callback KeyCallback = void();
+  callback CommandCallback = void(CommandResult result);
+  callback AppleScriptCallback = void(AppleScriptResult result);
+  callback DesktopTreeCallback = void(DesktopTree tree);
+  callback AppListCallback = void(AppInfo[] apps);
+  callback AppInfoCallback = void(AppInfo app);
+  callback LaunchCallback = void();
+  callback ScrollCallback = void();
+  callback ClipboardCallback = void(ClipboardContent content);
+  callback SetClipboardCallback = void();
+  callback ReadFileCallback = void(DOMString content);
+  callback WriteFileCallback = void();
+  callback ListDirCallback = void(FileEntry[] entries);
+
+  interface Functions {
+    // Check macOS permission status (accessibility, screen recording).
+    static void checkPermissions(PermissionStatusCallback callback);
+
+    // Request the user to grant a specific permission.
+    // |permissionType|: "accessibility" or "screenRecording".
+    static void requestPermission(DOMString permissionType,
+                                  VoidCallback callback);
+
+    // Capture a screenshot of the entire screen.
+    // |maxWidth|: Optional max width to downscale the image.
+    static void captureScreen(optional long maxWidth,
+                              ScreenshotCallback callback);
+
+    // Capture a screenshot of a specific window.
+    // |pid|: Process ID of the target application.
+    // |maxWidth|: Optional max width to downscale the image.
+    static void captureWindow(long pid,
+                              optional long maxWidth,
+                              ScreenshotCallback callback);
+
+    // Click at screen coordinates.
+    // |x|: X coordinate.
+    // |y|: Y coordinate.
+    static void click(long x, long y, ClickCallback callback);
+
+    // Double-click at screen coordinates.
+    static void doubleClick(long x, long y, ClickCallback callback);
+
+    // Right-click at screen coordinates.
+    static void rightClick(long x, long y, ClickCallback callback);
+
+    // Move the mouse to screen coordinates.
+    static void mouseMove(long x, long y, VoidCallback callback);
+
+    // Scroll at screen coordinates.
+    // |x|: X coordinate.
+    // |y|: Y coordinate.
+    // |deltaX|: Horizontal scroll amount.
+    // |deltaY|: Vertical scroll amount.
+    static void scroll(long x, long y, long deltaX, long deltaY,
+                       ScrollCallback callback);
+
+    // Type text using keyboard events.
+    // |text|: The text to type.
+    static void type(DOMString text, TypeCallback callback);
+
+    // Press a key with optional modifiers.
+    // |key|: Key name (e.g. "Return", "Tab", "Escape", "a").
+    // |modifiers|: Optional modifier flags — sum of: shift=1, control=2,
+    //              option=4, command=8.
+    static void pressKey(DOMString key,
+                         optional long modifiers,
+                         KeyCallback callback);
+
+    // Run a shell command.
+    // |command|: The command string to execute.
+    // |cwd|: Optional working directory.
+    // |timeout|: Optional timeout in milliseconds (default 30000).
+    static void runCommand(DOMString command,
+                           optional DOMString cwd,
+                           optional long timeout,
+                           CommandCallback callback);
+
+    // Run an AppleScript.
+    // |script|: The AppleScript source code.
+    static void runAppleScript(DOMString script,
+                               AppleScriptCallback callback);
+
+    // Get the accessibility tree of a running application.
+    // |pid|: Process ID. If 0, uses the frontmost app.
+    static void getDesktopTree(optional long pid,
+                               DesktopTreeCallback callback);
+
+    // List running applications.
+    static void listApps(AppListCallback callback);
+
+    // Get the currently active (frontmost) application.
+    static void getActiveApp(AppInfoCallback callback);
+
+    // Launch an application by name.
+    // |appName|: Application name (e.g. "Terminal", "Safari").
+    static void launchApp(DOMString appName, LaunchCallback callback);
+
+    // Get clipboard text content.
+    static void getClipboard(ClipboardCallback callback);
+
+    // Set clipboard text content.
+    // |text|: Text to copy to clipboard.
+    static void setClipboard(DOMString text, SetClipboardCallback callback);
+
+    // Read a file's text content.
+    // |path|: Absolute file path.
+    static void readFile(DOMString path, ReadFileCallback callback);
+
+    // Write text content to a file.
+    // |path|: Absolute file path.
+    // |content|: Text content to write.
+    static void writeFile(DOMString path, DOMString content,
+                          WriteFileCallback callback);
+
+    // List directory contents.
+    // |path|: Absolute directory path.
+    static void listDir(DOMString path, ListDirCallback callback);
+  };
+};
