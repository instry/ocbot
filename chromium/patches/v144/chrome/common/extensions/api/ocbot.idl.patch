+// Copyright 2025 The Chromium Authors
+// Use of this source code is governed by a BSD-style license that can be
+// found in the LICENSE file.
+
+// Use the <code>chrome.ocbot</code> API to access Ocbot browser features.
+namespace ocbot {
+  dictionary BrowserInfo {
+    // Browser kind: "chrome", "brave", "edge", or "chromium".
+    DOMString kind;
+    // Full path to the browser's user data directory.
+    DOMString userDataDir;
+  };
+
+  dictionary ProfileInfo {
+    // Profile directory name, e.g. "Default", "Profile 1".
+    DOMString directory;
+    // User-visible display name, e.g. "Work".
+    DOMString name;
+    // Full path to the profile directory.
+    DOMString path;
+  };
+
+  dictionary BrowserProfilesResult {
+    // Information about the browser.
+    BrowserInfo browser;
+    // Profiles found in this browser.
+    ProfileInfo[] profiles;
+  };
+
+  callback GetBrowserProfilesCallback = void(BrowserProfilesResult[] results);
+  callback InstallSkillCallback = void();
+  callback UninstallSkillCallback = void();
+
+  interface Functions {
+    // Returns a list of installed Chromium-based browsers and their profiles.
+    static void getBrowserProfiles(GetBrowserProfilesCallback callback);
+    // Installs a Marketplace skill into the managed workspace.
+    static void installSkill(DOMString slug, DOMString version, InstallSkillCallback callback);
+    // Removes a managed Marketplace skill from the local workspace.
+    static void uninstallSkill(DOMString slug, UninstallSkillCallback callback);
+  };
+};
