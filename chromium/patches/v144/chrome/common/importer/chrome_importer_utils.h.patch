+// found in the LICENSE file.
+
+#ifndef CHROME_COMMON_IMPORTER_CHROME_IMPORTER_UTILS_H_
+#define CHROME_COMMON_IMPORTER_CHROME_IMPORTER_UTILS_H_
+
+#include <stdint.h>
+
+#include <optional>
+#include <string>
+#include <vector>
+
+#include "build/build_config.h"
+
+namespace base {
+class FilePath;
+}
+
+struct ChromeProfileInfo {
+  std::string dir_name;     // e.g. "Default", "Profile 1"
+  std::string display_name; // e.g. "Person 1", from Local State
+};
+
+// Returns the platform-specific path to Chrome's user data directory.
+base::FilePath GetChromeUserDataPath();
+
+// Parses Chrome's "Local State" JSON file to enumerate profiles.
+// Returns a vector of profile info structs.
+std::vector<ChromeProfileInfo> GetChromeProfiles(
+    const base::FilePath& user_data_path);
+
+// Checks which data types can be imported from the given Chrome profile path.
+// Sets |services_supported| bitmask. Returns true if any data can be imported.
+bool ChromeImporterCanImport(const base::FilePath& profile_path,
+                             uint16_t* services_supported);
+
+#if BUILDFLAG(IS_MAC)
+// Retrieves the Chrome Safe Storage encryption key from the macOS Keychain.
+// Returns the raw password string, or nullopt on failure.
+std::optional<std::string> GetChromeEncryptionKey();
+
+// Decrypts a Chrome encrypted blob (from Login Data or Cookies).
+// Chrome on macOS uses AES-128-CBC with a PBKDF2-derived key.
+// The blob starts with "v10" (3-byte version prefix).
+// Returns the decrypted plaintext, or empty string on failure.
+std::string DecryptChromeValue(const std::string& encrypted_value,
+                               const std::string& encryption_key);
+#endif  // BUILDFLAG(IS_MAC)
+
+#endif  // CHROME_COMMON_IMPORTER_CHROME_IMPORTER_UTILS_H_
