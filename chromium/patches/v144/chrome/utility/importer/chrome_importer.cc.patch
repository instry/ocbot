+namespace {
+
+inline constexpr sql::Database::Tag kDatabaseTag{"ChromeImporter"};
+
+// Chrome stores timestamps as microseconds since Windows epoch (1601-01-01).
+// This is the same internal representation as base::Time on Windows, and
+// base::Time::FromInternalValue() handles it on all platforms.
+base::Time ChromeTimeToBaseTime(int64_t chrome_time) {
+  return base::Time::FromDeltaSinceWindowsEpoch(
+      base::Microseconds(chrome_time));
+}
+
+bool CanImportURL(const GURL& url) {
+  if (!url.is_valid()) {
+    return false;
+  }
+  // Filter out internal Chrome URLs.
+  const char* const kInvalidSchemes[] = {"chrome", "chrome-extension",
+                                         "chrome-devtools", "about"};
+  for (const auto* scheme : kInvalidSchemes) {
+    if (url.SchemeIs(scheme)) {
+      return false;
+    }
+  }
+  return true;
+}
+
+}  // namespace
+
+ChromeImporter::ChromeImporter() = default;
+
+ChromeImporter::~ChromeImporter() = default;
+
+void ChromeImporter::StartImport(
+    const user_data_importer::SourceProfile& source_profile,
+    uint16_t items,
+    ImporterBridge* bridge) {
+  bridge_ = bridge;
+  source_path_ = source_profile.source_path;
+
+  bridge_->NotifyStarted();
+  if (!source_path_copy_.CreateUniqueTempDir()) {
+    bridge_->NotifyEnded();
+    return;
+  }
+
+  // Import history before bookmarks (same rationale as Firefox importer:
+  // favicons are stored for URLs that exist in history or bookmarks).
+  if ((items & user_data_importer::HISTORY) && !cancelled()) {
+    bridge_->NotifyItemStarted(user_data_importer::HISTORY);
+    ImportHistory();
+    bridge_->NotifyItemEnded(user_data_importer::HISTORY);
+  }
+
+  if ((items & user_data_importer::FAVORITES) && !cancelled()) {
+    bridge_->NotifyItemStarted(user_data_importer::FAVORITES);
+    ImportBookmarks();
+    bridge_->NotifyItemEnded(user_data_importer::FAVORITES);
+  }
+
+  bridge_->NotifyEnded();
+}
+
+void ChromeImporter::ImportBookmarks() {
+  base::FilePath bookmarks_path = source_path_.Append(
+      FILE_PATH_LITERAL("Bookmarks"));
+  if (!base::PathExists(bookmarks_path)) {
+    return;
+  }
+
+  JSONFileValueDeserializer deserializer(bookmarks_path);
+  int error_code = 0;
+  std::string error_message;
+  std::unique_ptr<base::Value> root =
+      deserializer.Deserialize(&error_code, &error_message);
+  if (!root || !root->is_dict()) {
+    return;
+  }
+
+  const base::Value::Dict* roots = root->GetDict().FindDict("roots");
+  if (!roots) {
+    return;
+  }
+
+  std::vector<user_data_importer::ImportedBookmarkEntry> bookmarks;
+
+  // Chrome has three root folders: bookmark_bar, other, synced.
+  const base::Value::Dict* bookmark_bar = roots->FindDict("bookmark_bar");
+  if (bookmark_bar) {
+    std::vector<std::u16string> path;
+    RecursiveReadBookmarksFolder(*bookmark_bar, path,
+                                 /*is_in_toolbar=*/true, &bookmarks);
+  }
+
+  const base::Value::Dict* other = roots->FindDict("other");
+  if (other) {
+    std::vector<std::u16string> path;
+    RecursiveReadBookmarksFolder(*other, path,
+                                 /*is_in_toolbar=*/false, &bookmarks);
+  }
+
+  const base::Value::Dict* synced = roots->FindDict("synced");
+  if (synced) {
+    std::vector<std::u16string> path;
+    RecursiveReadBookmarksFolder(*synced, path,
+                                 /*is_in_toolbar=*/false, &bookmarks);
+  }
+
+  if (!bookmarks.empty() && !cancelled()) {
+    const std::u16string& first_folder_name =
+        bridge_->GetLocalizedString(IDS_BOOKMARK_GROUP_FROM_CHROME);
+    bridge_->AddBookmarks(bookmarks, first_folder_name);
+  }
+}
+
+void ChromeImporter::RecursiveReadBookmarksFolder(
+    const base::Value::Dict& folder,
+    const std::vector<std::u16string>& parent_path,
+    bool is_in_toolbar,
+    std::vector<user_data_importer::ImportedBookmarkEntry>* bookmarks) {
+  const base::Value::List* children = folder.FindList("children");
+  if (!children) {
+    return;
+  }
+
+  for (const auto& child_value : *children) {
+    if (cancelled()) {
+      return;
+    }
+
+    if (!child_value.is_dict()) {
+      continue;
+    }
+    const base::Value::Dict& child = child_value.GetDict();
+
+    const std::string* type = child.FindString("type");
+    if (!type) {
+      continue;
+    }
+
+    const std::string* name = child.FindString("name");
+    std::u16string title = name ? base::UTF8ToUTF16(*name) : u"";
+
+    if (*type == "folder") {
+      std::vector<std::u16string> path = parent_path;
+      path.push_back(title);
+      RecursiveReadBookmarksFolder(child, path, is_in_toolbar, bookmarks);
+    } else if (*type == "url") {
+      const std::string* url_str = child.FindString("url");
+      if (!url_str) {
+        continue;
+      }
+      GURL url(*url_str);
+      if (!CanImportURL(url)) {
+        continue;
+      }
+
+      user_data_importer::ImportedBookmarkEntry entry;
+      entry.title = title;
+      entry.url = url;
+      entry.path = parent_path;
+      entry.in_toolbar = is_in_toolbar;
+      entry.is_folder = false;
+
+      // Parse date_added (microseconds since Windows epoch as string).
+      const std::string* date_added_str = child.FindString("date_added");
+      if (date_added_str) {
+        int64_t date_added_val = 0;
+        if (base::StringToInt64(*date_added_str, &date_added_val)) {
+          entry.creation_time = ChromeTimeToBaseTime(date_added_val);
+        }
+      }
+
+      bookmarks->push_back(entry);
+    }
+  }
+}
+
+void ChromeImporter::ImportHistory() {
+  base::FilePath file = GetCopiedSourcePath("History");
+  if (file.empty()) {
+    return;
+  }
+
+  sql::Database db(kDatabaseTag);
+  if (!db.Open(file)) {
+    return;
+  }
+
+  const char query[] =
+      "SELECT url, title, visit_count, typed_count, last_visit_time, hidden "
+      "FROM urls";
+
+  sql::Statement s(db.GetUniqueStatement(query));
+  if (!s.is_valid()) {
+    return;
+  }
+
+  std::vector<user_data_importer::ImporterURLRow> rows;
+  while (s.Step() && !cancelled()) {
+    GURL url(s.ColumnStringView(0));
+    if (!CanImportURL(url)) {
+      continue;
+    }
+
+    user_data_importer::ImporterURLRow row(url);
+    row.title = s.ColumnString16(1);
+    row.visit_count = s.ColumnInt(2);
+    row.typed_count = s.ColumnInt(3);
+    // Chrome stores last_visit_time as microseconds since Windows epoch.
+    row.last_visit = ChromeTimeToBaseTime(s.ColumnInt64(4));
+    row.hidden = s.ColumnInt(5) == 1;
+
+    rows.push_back(row);
+  }
+
+  if (!rows.empty() && !cancelled()) {
+    bridge_->SetHistoryItems(rows,
+                             user_data_importer::VISIT_SOURCE_CHROME_IMPORTED);
+  }
+}
+
+base::FilePath ChromeImporter::GetCopiedSourcePath(
+    std::string_view base_file_name) {
+  const base::FilePath file = source_path_.AppendASCII(base_file_name);
+  if (!base::PathExists(file)) {
+    return {};
+  }
+  DCHECK(source_path_copy_.IsValid());
+  const base::FilePath destination =
+      source_path_copy_.GetPath().AppendASCII(base_file_name);
+  if (!base::CopyFile(file, destination)) {
+    return {};
+  }
+  return destination;
+}
