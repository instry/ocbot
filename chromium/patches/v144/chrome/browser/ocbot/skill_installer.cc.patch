+namespace {
+
+constexpr int64_t kMaxZipSize = 200LL * 1024 * 1024;
+constexpr char kConvexSiteBase[] = "https://wry-manatee-359.convex.site";
+constexpr char kRegistryBase[] = "https://wry-manatee-359.convex.site";
+
+network::mojom::URLLoaderFactory* GetURLLoaderFactory() {
+  return SystemNetworkContextManager::GetInstance()->GetURLLoaderFactory();
+}
+
+base::FilePath GetWorkspaceDir() {
+#if BUILDFLAG(IS_MAC)
+  base::FilePath home_dir;
+  if (!base::PathService::Get(base::DIR_HOME, &home_dir)) {
+    return base::FilePath();
+  }
+  return home_dir.Append(FILE_PATH_LITERAL("Library"))
+      .Append(FILE_PATH_LITERAL("Application Support"))
+      .Append(FILE_PATH_LITERAL("Ocbot"))
+      .Append(FILE_PATH_LITERAL("openclaw-workspace"));
+#elif BUILDFLAG(IS_WIN)
+  base::FilePath appdata_dir;
+  if (!base::PathService::Get(base::DIR_ROAMING_APP_DATA, &appdata_dir)) {
+    return base::FilePath();
+  }
+  return appdata_dir.Append(FILE_PATH_LITERAL("Ocbot"))
+      .Append(FILE_PATH_LITERAL("openclaw-workspace"));
+#else
+  base::FilePath home_dir;
+  if (!base::PathService::Get(base::DIR_HOME, &home_dir)) {
+    return base::FilePath();
+  }
+  return home_dir.Append(FILE_PATH_LITERAL(".config"))
+      .Append(FILE_PATH_LITERAL("ocbot"))
+      .Append(FILE_PATH_LITERAL("openclaw-workspace"));
+#endif
+}
+
+base::FilePath GetSkillsDir() {
+  base::FilePath ws = GetWorkspaceDir();
+  if (ws.empty()) return base::FilePath();
+  return ws.Append(FILE_PATH_LITERAL("skills"));
+}
+
+bool WriteJsonFile(const base::FilePath& path, const base::Value::Dict& dict) {
+  std::string json;
+  if (!base::JSONWriter::WriteWithOptions(
+          dict, base::JSONWriter::OPTIONS_PRETTY_PRINT, &json)) {
+    return false;
+  }
+  base::CreateDirectory(path.DirName());
+  return base::WriteFile(path, json);
+}
+
+bool ExtractZip(const base::FilePath& zip_path, const base::FilePath& dest_dir) {
+  base::CreateDirectory(dest_dir);
+#if BUILDFLAG(IS_WIN)
+  // On Windows, prefer PowerShell's Expand-Archive.
+  std::vector<std::string> argv = {
+      "powershell", "-NoProfile", "-Command",
+      "Expand-Archive -Force -Path \"" + zip_path.value() + "\" -DestinationPath \"" + dest_dir.value() + "\""};
+#else
+  std::vector<std::string> argv = {"unzip", "-q", zip_path.value(), "-d", dest_dir.value()};
+#endif
+  base::LaunchOptions options;
+#if BUILDFLAG(IS_WIN)
+  options.start_hidden = true;
+#endif
+  base::Process process = base::LaunchProcess(argv, options);
+  if (!process.IsValid()) {
+    LOG(ERROR) << "ocbot skill installer: failed to launch unzip";
+    return false;
+  }
+  int exit_code = -1;
+  if (!process.WaitForExit(&exit_code) || exit_code != 0) {
+    LOG(ERROR) << "ocbot skill installer: unzip exited with " << exit_code;
+    return false;
+  }
+  return true;
+}
+
+base::FilePath FindSkillRoot(const base::FilePath& extract_dir) {
+  // If SKILL.md exists at root, use it.
+  base::FilePath marker = extract_dir.Append(FILE_PATH_LITERAL("SKILL.md"));
+  if (base::PathExists(marker)) {
+    return extract_dir;
+  }
+  // Otherwise, check single top-level directory.
+  base::FileEnumerator e(extract_dir, /*recursive=*/false,
+                         base::FileEnumerator::DIRECTORIES);
+  base::FilePath sub = e.Next();
+  if (sub.empty()) {
+    return base::FilePath();
+  }
+  // Ensure only one subdir considered; ignore multiple entries.
+  base::FilePath second = e.Next();
+  if (!second.empty()) {
+    return base::FilePath();
+  }
+  if (base::PathExists(sub.Append(FILE_PATH_LITERAL("SKILL.md")))) {
+    return sub;
+  }
+  return base::FilePath();
+}
+
+void FinalizeInstall(const base::FilePath& target_dir,
+                     const std::string& slug,
+                     const std::string& version) {
+  // Write .clawhub/origin.json
+  base::Value::Dict origin;
+  origin.Set("version", 1);
+  origin.Set("registry", kRegistryBase);
+  origin.Set("slug", slug);
+  origin.Set("installedVersion", version.empty() ? "latest" : version);
+  origin.Set("installedAt",
+             static_cast<int64_t>(base::Time::Now().InMillisecondsSinceUnixEpoch()));
+  base::FilePath origin_path = target_dir.Append(FILE_PATH_LITERAL(".clawhub"))
+                                  .Append(FILE_PATH_LITERAL("origin.json"));
+  if (!WriteJsonFile(origin_path, origin)) {
+    LOG(WARNING) << "ocbot skill installer: failed to write origin.json";
+  }
+
+  // Update workspace lockfile: <workspace>/.clawhub/lock.json
+  base::FilePath ws = GetWorkspaceDir();
+  base::FilePath lock_path = ws.Append(FILE_PATH_LITERAL(".clawhub"))
+                             .Append(FILE_PATH_LITERAL("lock.json"));
+  base::Value::Dict lock;
+  // Try read existing.
+  std::string existing;
+  if (base::ReadFileToString(lock_path, &existing)) {
+    if (auto dict = base::JSONReader::ReadDict(existing, base::JSON_PARSE_RFC)) {
+      lock = std::move(*dict);
+    }
+  }
+  // Ensure basic structure.
+  lock.Set("version", 1);
+  base::Value::Dict* skills = lock.FindDict("skills");
+  if (!skills) {
+    lock.Set("skills", base::Value::Dict());
+    skills = lock.FindDict("skills");
+  }
+  base::Value::Dict entry;
+  entry.Set("version", version.empty() ? "latest" : version);
+  entry.Set("installedAt",
+            static_cast<int64_t>(base::Time::Now().InMillisecondsSinceUnixEpoch()));
+  skills->Set(slug, std::move(entry));
+  if (!WriteJsonFile(lock_path, lock)) {
+    LOG(WARNING) << "ocbot skill installer: failed to write lock.json";
+  }
+}
+
+void DoInstall(content::BrowserContext* browser_context,
+               std::string slug,
+               std::string version) {
+  LOG(INFO) << "ocbot skill install: slug=" << slug << " version=" << version;
+  // Determine workspace and target skill directory.
+  base::FilePath skills_dir = GetSkillsDir();
+  if (skills_dir.empty()) {
+    LOG(ERROR) << "ocbot skill installer: cannot resolve workspace dir";
+    return;
+  }
+  base::CreateDirectory(skills_dir);
+  base::FilePath target_dir = skills_dir.AppendASCII(slug);
+
+  // Build download URL.
+  GURL url(std::string(kConvexSiteBase) + "/api/v1/download?slug=" + slug +
+           (version.empty() ? "" : "&version=" + version));
+
+  auto request = std::make_unique<network::ResourceRequest>();
+  request->url = url;
+  request->method = "GET";
+  request->load_flags = net::LOAD_DISABLE_CACHE;
+  request->credentials_mode = network::mojom::CredentialsMode::kOmit;
+
+  auto loader = network::SimpleURLLoader::Create(std::move(request),
+                                                 net::DefineNetworkTrafficAnnotation(
+                                                     "ocbot_skill_installer", R"(
+        semantics {
+          sender: "Ocbot Skill Installer"
+          description:
+            "Downloads skill archives from ClawHub and installs locally."
+          trigger:
+            "User initiates install from Marketplace UI."
+          data: "No user data; fetches public skill zip."
+          destination: OTHER
+          internal {
+            contacts {
+              email: "niceboybao@gmail.com"
+            }
+          }
+          user_data {
+            type: NONE
+          }
+          last_reviewed: "2026-03-26"
+        }
+        policy {
+          cookies_allowed: NO
+          setting: "Not configurable."
+          policy_exception_justification:
+            "Required for local installation."
+        })"));
+  loader->SetRetryOptions(2, network::SimpleURLLoader::RETRY_ON_NETWORK_CHANGE);
+
+  loader->DownloadToTempFile(
+      GetURLLoaderFactory(),
+      base::BindOnce(
+          [](base::FilePath target_dir, std::string slug, std::string version,
+             std::unique_ptr<network::SimpleURLLoader> loader,
+             base::FilePath temp_path) {
+            if (temp_path.empty()) {
+              LOG(ERROR) << "ocbot skill installer: download failed (net "
+                         << loader->NetError() << ")";
+              return;
+            }
+            // Extract zip to temp dir.
+            base::FilePath ws = GetWorkspaceDir();
+            base::FilePath temp_extract =
+                ws.Append(FILE_PATH_LITERAL("tmp"))
+                  .AppendASCII("skill-" + slug + "-" + base::NumberToString(base::Time::Now().InSeconds()))
+                  ;
+            if (!ExtractZip(temp_path, temp_extract)) {
+              LOG(ERROR) << "ocbot skill installer: extraction failed";
+              base::DeleteFile(temp_path);
+              base::DeletePathRecursively(temp_extract);
+              return;
+            }
+            base::DeleteFile(temp_path);
+            // Determine skill root.
+            base::FilePath root = FindSkillRoot(temp_extract);
+            if (root.empty()) {
+              LOG(ERROR) << "ocbot skill installer: SKILL.md not found in archive";
+              base::DeletePathRecursively(temp_extract);
+              return;
+            }
+            // Install to target dir.
+            base::DeletePathRecursively(target_dir);
+            base::CreateDirectory(target_dir);
+            if (!base::CopyDirectory(root, target_dir, /*recursive=*/true)) {
+              LOG(ERROR) << "ocbot skill installer: failed to copy files";
+              base::DeletePathRecursively(temp_extract);
+              return;
+            }
+            base::DeletePathRecursively(temp_extract);
+            // Write origin and lockfile.
+            FinalizeInstall(target_dir, slug, version);
+            LOG(INFO) << "ocbot skill installer: installed " << slug << " to " << target_dir;
+          },
+          target_dir, slug, version, base::Owned(std::move(loader))),
+      kMaxZipSize);
+}
+
+}  // namespace
+
+void InstallSkillBySlug(content::BrowserContext* browser_context,
+                        const std::string& slug,
+                        const std::string& version) {
+  if (!browser_context) return;
+  content::GetUIThreadTaskRunner({})->PostTask(
+      FROM_HERE,
+      base::BindOnce(&DoInstall,
+                     browser_context,
+                     std::string(slug),
+                     std::string(version)));
+}
+
+}  // namespace ocbot
