+#ifndef CHROME_BROWSER_OCBOT_BROWSER_UPDATER_H_
+#define CHROME_BROWSER_OCBOT_BROWSER_UPDATER_H_
+
+#include <memory>
+#include <optional>
+#include <string>
+
+#include "base/files/file_path.h"
+#include "base/memory/weak_ptr.h"
+#include "base/timer/timer.h"
+
+namespace network {
+class SimpleURLLoader;
+namespace mojom {
+class URLLoaderFactory;
+}
+}  // namespace network
+
+namespace ocbot {
+
+// Downloads and installs Ocbot browser updates.
+//
+// Workflow:
+//   1. After a startup delay, fetches latest.json from R2 CDN.
+//   2. On failure, falls back to GitHub Releases API.
+//   3. Compares the remote version against the running browser version.
+//   4. If newer, downloads the DMG asset.
+//   5. Mounts DMG, rsyncs the new .app over the current one, unmounts.
+//   6. Chromium's built-in UpgradeDetector picks up the disk version change
+//      and shows the "Relaunch to update" UI.
+//
+// Subsequent checks run every 4 hours while the browser is open.
+class OcbotBrowserUpdater {
+ public:
+  OcbotBrowserUpdater();
+  ~OcbotBrowserUpdater();
+
+  OcbotBrowserUpdater(const OcbotBrowserUpdater&) = delete;
+  OcbotBrowserUpdater& operator=(const OcbotBrowserUpdater&) = delete;
+
+  // Starts the periodic update check. First check after 60s.
+  void Start();
+
+ private:
+  void CheckForUpdate();
+  void OnR2MetadataFetched(std::optional<std::string> response_body);
+  void CheckForUpdateFromGitHub();
+  void OnReleaseFetched(std::optional<std::string> response_body);
+  void DownloadDmg(const std::string& url, const std::string& version);
+  void OnDmgDownloaded(const std::string& version, base::FilePath tmp);
+  static bool InstallFromDmg(const base::FilePath& dmg,
+                              const base::FilePath& app);
+  void OnInstallComplete(const std::string& version, bool success);
+  std::string GetRunningVersion() const;
+  base::FilePath GetCurrentAppPath() const;
+  network::mojom::URLLoaderFactory* GetURLLoaderFactory();
+
+  base::RepeatingTimer check_timer_;
+  std::unique_ptr<network::SimpleURLLoader> url_loader_;
+  base::WeakPtrFactory<OcbotBrowserUpdater> weak_factory_{this};
+};
+
+}  // namespace ocbot
+
+#endif  // CHROME_BROWSER_OCBOT_BROWSER_UPDATER_H_
