+constexpr char kR2LatestUrl[] = "https://cdn.oc.bot/latest.json";
+constexpr char kGitHubReleasesApiUrl[] =
+    "https://api.github.com/repos/instry/ocbot/releases/latest";
+constexpr char kDmgAssetPrefix[] = "Ocbot-";
+constexpr char kDmgAssetSuffix[] = ".dmg";
+
+// First check 60 seconds after startup.
+constexpr base::TimeDelta kInitialDelay = base::Seconds(60);
+// Subsequent checks every 4 hours.
+constexpr base::TimeDelta kCheckInterval = base::Hours(4);
+// Max response size for GitHub API JSON (256 KB).
+constexpr int kMaxApiResponseSize = 256 * 1024;
+// Max DMG download size (500 MB).
+constexpr int kMaxDmgSize = 500 * 1024 * 1024;
+
+const net::NetworkTrafficAnnotationTag kTrafficAnnotation =
+    net::DefineNetworkTrafficAnnotation("ocbot_browser_updater", R"(
+        semantics {
+          sender: "Ocbot Browser Updater"
+          description:
+            "Checks GitHub Releases for Ocbot browser updates and "
+            "downloads new DMG versions when available."
+          trigger:
+            "Periodically after browser startup (every 4 hours)."
+          data: "No user data is sent. Only fetches public release metadata."
+          destination: OTHER
+          internal {
+            contacts {
+              email: "niceboybao@gmail.com"
+            }
+          }
+          user_data {
+            type: NONE
+          }
+          last_reviewed: "2025-01-01"
+        }
+        policy {
+          cookies_allowed: NO
+          setting: "Not configurable."
+          policy_exception_justification:
+            "Essential for keeping the Ocbot browser up to date."
+        })");
+
+// Parses GitHub release JSON to extract version and DMG download URL.
+// Looks for an asset matching "Ocbot-*.dmg".
+bool ParseReleaseJson(const std::string& json,
+                      std::string* out_version,
+                      std::string* out_download_url) {
+  auto result = base::JSONReader::ReadDict(json, base::JSON_PARSE_RFC);
+  if (!result) {
+    LOG(WARNING) << "ocbot browser updater: invalid JSON";
+    return false;
+  }
+
+  const base::DictValue& dict = *result;
+
+  // tag_name is like "v0.2.0"
+  const std::string* tag = dict.FindString("tag_name");
+  if (!tag) {
+    return false;
+  }
+
+  // Strip "v" prefix
+  std::string version = *tag;
+  if (version.starts_with("v")) {
+    version = version.substr(1);
+  }
+
+  if (!base::Version(version).IsValid()) {
+    LOG(WARNING) << "ocbot browser updater: invalid version in tag: " << *tag;
+    return false;
+  }
+
+  // Find the DMG asset (Ocbot-*.dmg)
+  const base::ListValue* assets = dict.FindList("assets");
+  if (!assets) {
+    return false;
+  }
+
+  for (const auto& asset_value : *assets) {
+    const base::DictValue* asset = asset_value.GetIfDict();
+    if (!asset) {
+      continue;
+    }
+    const std::string* name = asset->FindString("name");
+    if (name && name->starts_with(kDmgAssetPrefix) &&
+        name->ends_with(kDmgAssetSuffix)) {
+      const std::string* url = asset->FindString("browser_download_url");
+      if (url) {
+        *out_version = version;
+        *out_download_url = *url;
+        return true;
+      }
+    }
+  }
+
+  LOG(WARNING) << "ocbot browser updater: no DMG asset found in release "
+               << *tag;
+  return false;
+}
+
+// Parses R2 CDN latest.json to extract version and browser download URL.
+bool ParseR2Json(const std::string& json,
+                 std::string* out_version,
+                 std::string* out_download_url) {
+  auto result = base::JSONReader::ReadDict(json, base::JSON_PARSE_RFC);
+  if (!result) {
+    LOG(WARNING) << "ocbot browser updater: invalid R2 JSON";
+    return false;
+  }
+
+  const base::DictValue& dict = *result;
+
+  const std::string* version = dict.FindString("version");
+  if (!version || !base::Version(*version).IsValid()) {
+    LOG(WARNING) << "ocbot browser updater: invalid or missing version in R2 JSON";
+    return false;
+  }
+
+  const base::DictValue* browser = dict.FindDict("browser");
+  if (!browser) {
+    LOG(WARNING) << "ocbot browser updater: no browser entry in R2 JSON";
+    return false;
+  }
+
+  const base::DictValue* platform = browser->FindDict("macos");
+  if (!platform) {
+    LOG(WARNING) << "ocbot browser updater: no macos entry in R2 JSON";
+    return false;
+  }
+
+  const std::string* url = platform->FindString("url");
+  if (!url || url->empty()) {
+    LOG(WARNING) << "ocbot browser updater: no macOS URL in R2 JSON";
+    return false;
+  }
+
+  *out_version = *version;
+  *out_download_url = *url;
+  return true;
+}
+
+// Runs on a background thread. Mounts DMG, rsyncs app, unmounts.
+bool InstallFromDmgBlocking(const base::FilePath& dmg_path,
+                            const base::FilePath& app_path) {
+  // Create a temporary mount point.
+  base::FilePath mount_point;
+  if (!base::CreateNewTempDirectory(FILE_PATH_LITERAL("ocbot_dmg_"),
+                                    &mount_point)) {
+    LOG(ERROR) << "ocbot browser updater: failed to create temp mount point";
+    return false;
+  }
+
+  // 1. Mount DMG
+  std::vector<std::string> mount_cmd = {
+      "/usr/bin/hdiutil", "attach",
+      dmg_path.value(),
+      "-mountpoint", mount_point.value(),
+      "-nobrowse", "-readonly", "-noverify", "-noautofsck"};
+
+  std::string mount_output;
+  if (!base::GetAppOutputAndError(base::CommandLine(mount_cmd),
+                                  &mount_output)) {
+    LOG(ERROR) << "ocbot browser updater: hdiutil attach failed: "
+               << mount_output;
+    base::DeletePathRecursively(mount_point);
+    return false;
+  }
+
+  // 2. Find Ocbot.app in mount point
+  base::FilePath mounted_app = mount_point.Append("Ocbot.app");
+  if (!base::PathExists(mounted_app)) {
+    // Try to find any .app in the mount point
+    base::FileEnumerator enumerator(mount_point, /*recursive=*/false,
+                                    base::FileEnumerator::DIRECTORIES);
+    for (base::FilePath path = enumerator.Next(); !path.empty();
+         path = enumerator.Next()) {
+      if (path.Extension() == ".app") {
+        mounted_app = path;
+        break;
+      }
+    }
+    if (!base::PathExists(mounted_app)) {
+      LOG(ERROR) << "ocbot browser updater: no .app found in DMG";
+      base::GetAppOutputAndError(
+          base::CommandLine({"/usr/bin/hdiutil", "detach",
+                             mount_point.value(), "-quiet"}),
+          &mount_output);
+      base::DeletePathRecursively(mount_point);
+      return false;
+    }
+  }
+
+  // 3. rsync the new app over the current one
+  // Trailing slash on source means "contents of directory"
+  std::string source = mounted_app.value() + "/";
+  std::string dest = app_path.value() + "/";
+
+  std::vector<std::string> rsync_cmd = {
+      "/usr/bin/rsync", "-a", "--delete", source, dest};
+
+  std::string rsync_output;
+  bool rsync_ok = base::GetAppOutputAndError(
+      base::CommandLine(rsync_cmd), &rsync_output);
+
+  // 4. Detach DMG (always attempt, even if rsync failed)
+  std::string detach_output;
+  base::GetAppOutputAndError(
+      base::CommandLine({"/usr/bin/hdiutil", "detach",
+                         mount_point.value(), "-quiet"}),
+      &detach_output);
+
+  // 5. Clean up mount point and DMG
+  base::DeletePathRecursively(mount_point);
+  base::DeleteFile(dmg_path);
+
+  if (!rsync_ok) {
+    LOG(WARNING) << "ocbot browser updater: rsync failed (permission denied?): "
+                 << rsync_output;
+    return false;
+  }
+
+  return true;
+}
