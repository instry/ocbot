+
+OcbotBrowserUpdater::OcbotBrowserUpdater() = default;
+
+OcbotBrowserUpdater::~OcbotBrowserUpdater() = default;
+
+void OcbotBrowserUpdater::Start() {
+  DCHECK_CURRENTLY_ON(content::BrowserThread::UI);
+
+  // Repeat every kCheckInterval.
+  check_timer_.Start(
+      FROM_HERE, kCheckInterval,
+      base::BindRepeating(&OcbotBrowserUpdater::CheckForUpdate,
+                           weak_factory_.GetWeakPtr()));
+
+  // Faster first check after kInitialDelay.
+  content::GetUIThreadTaskRunner({})->PostDelayedTask(
+      FROM_HERE,
+      base::BindOnce(&OcbotBrowserUpdater::CheckForUpdate,
+                     weak_factory_.GetWeakPtr()),
+      kInitialDelay);
+}
+
+void OcbotBrowserUpdater::CheckForUpdate() {
+  DCHECK_CURRENTLY_ON(content::BrowserThread::UI);
+
+  // Skip if a download/install is already in progress.
+  if (url_loader_) {
+    return;
+  }
+
+  auto* loader_factory = GetURLLoaderFactory();
+  if (!loader_factory) {
+    return;
+  }
+
+  LOG(INFO) << "ocbot browser updater: checking for browser updates (R2)...";
+
+  auto request = std::make_unique<network::ResourceRequest>();
+  request->url = GURL(kR2LatestUrl);
+  request->method = "GET";
+  request->load_flags = net::LOAD_DISABLE_CACHE;
+  request->credentials_mode = network::mojom::CredentialsMode::kOmit;
+
+  url_loader_ =
+      network::SimpleURLLoader::Create(std::move(request), kTrafficAnnotation);
+  url_loader_->SetRetryOptions(
+      1, network::SimpleURLLoader::RETRY_ON_NETWORK_CHANGE);
+
+  url_loader_->DownloadToString(
+      loader_factory,
+      base::BindOnce(&OcbotBrowserUpdater::OnR2MetadataFetched,
+                     weak_factory_.GetWeakPtr()),
+      kMaxApiResponseSize);
+}
+
+void OcbotBrowserUpdater::OnR2MetadataFetched(
+    std::optional<std::string> response_body) {
+  DCHECK_CURRENTLY_ON(content::BrowserThread::UI);
+
+  if (!response_body) {
+    LOG(WARNING) << "ocbot browser updater: R2 fetch failed (net error: "
+                 << url_loader_->NetError() << "), falling back to GitHub";
+    url_loader_.reset();
+    CheckForUpdateFromGitHub();
+    return;
+  }
+
+  url_loader_.reset();
+
+  std::string remote_version;
+  std::string download_url;
+  if (!ParseR2Json(*response_body, &remote_version, &download_url)) {
+    LOG(WARNING) << "ocbot browser updater: R2 JSON parse failed, "
+                 << "falling back to GitHub";
+    CheckForUpdateFromGitHub();
+    return;
+  }
+
+  std::string running_version = GetRunningVersion();
+  LOG(INFO) << "ocbot browser updater: running=" << running_version
+            << " remote=" << remote_version << " (via R2)";
+
+  base::Version current(running_version);
+  base::Version remote(remote_version);
+  if (!remote.IsValid() || !current.IsValid()) {
+    LOG(WARNING) << "ocbot browser updater: invalid version comparison";
+    return;
+  }
+
+  if (remote.CompareTo(current) <= 0) {
+    LOG(INFO) << "ocbot browser updater: already up to date";
+    return;
+  }
+
+  LOG(INFO) << "ocbot browser updater: new version " << remote_version
+            << " available, downloading DMG from R2...";
+  DownloadDmg(download_url, remote_version);
+}
+
+void OcbotBrowserUpdater::CheckForUpdateFromGitHub() {
+  DCHECK_CURRENTLY_ON(content::BrowserThread::UI);
+
+  auto* loader_factory = GetURLLoaderFactory();
+  if (!loader_factory) {
+    return;
+  }
+
+  LOG(INFO) << "ocbot browser updater: checking for browser updates (GitHub)...";
+
+  auto request = std::make_unique<network::ResourceRequest>();
+  request->url = GURL(kGitHubReleasesApiUrl);
+  request->method = "GET";
+  request->load_flags = net::LOAD_DISABLE_CACHE;
+  request->headers.SetHeader("Accept", "application/vnd.github.v3+json");
+  request->credentials_mode = network::mojom::CredentialsMode::kOmit;
+
+  url_loader_ =
+      network::SimpleURLLoader::Create(std::move(request), kTrafficAnnotation);
+  url_loader_->SetRetryOptions(
+      1, network::SimpleURLLoader::RETRY_ON_NETWORK_CHANGE);
+
+  url_loader_->DownloadToString(
+      loader_factory,
+      base::BindOnce(&OcbotBrowserUpdater::OnReleaseFetched,
+                     weak_factory_.GetWeakPtr()),
+      kMaxApiResponseSize);
+}
+
+void OcbotBrowserUpdater::OnReleaseFetched(
+    std::optional<std::string> response_body) {
+  DCHECK_CURRENTLY_ON(content::BrowserThread::UI);
+
+  if (!response_body) {
+    LOG(WARNING) << "ocbot browser updater: failed to fetch release info "
+                 << "(net error: " << url_loader_->NetError() << ")";
+    url_loader_.reset();
+    return;
+  }
+
+  url_loader_.reset();
+
+  std::string remote_version;
+  std::string download_url;
+  if (!ParseReleaseJson(*response_body, &remote_version, &download_url)) {
+    return;
+  }
+
+  std::string running_version = GetRunningVersion();
+  LOG(INFO) << "ocbot browser updater: running=" << running_version
+            << " remote=" << remote_version;
+
+  base::Version current(running_version);
+  base::Version remote(remote_version);
+  if (!remote.IsValid() || !current.IsValid()) {
+    LOG(WARNING) << "ocbot browser updater: invalid version comparison";
+    return;
+  }
+
+  if (remote.CompareTo(current) <= 0) {
+    LOG(INFO) << "ocbot browser updater: already up to date";
+    return;
+  }
+
+  LOG(INFO) << "ocbot browser updater: new version " << remote_version
+            << " available, downloading DMG...";
+  DownloadDmg(download_url, remote_version);
+}
+
+void OcbotBrowserUpdater::DownloadDmg(const std::string& url,
+                                       const std::string& version) {
+  DCHECK_CURRENTLY_ON(content::BrowserThread::UI);
+
+  auto* loader_factory = GetURLLoaderFactory();
+  if (!loader_factory) {
+    return;
+  }
+
+  auto request = std::make_unique<network::ResourceRequest>();
+  request->url = GURL(url);
+  request->method = "GET";
+  request->load_flags = net::LOAD_DISABLE_CACHE;
+  request->credentials_mode = network::mojom::CredentialsMode::kOmit;
+
+  url_loader_ =
+      network::SimpleURLLoader::Create(std::move(request), kTrafficAnnotation);
+  url_loader_->SetRetryOptions(
+      2, network::SimpleURLLoader::RETRY_ON_NETWORK_CHANGE);
+
+  url_loader_->DownloadToTempFile(
+      loader_factory,
+      base::BindOnce(&OcbotBrowserUpdater::OnDmgDownloaded,
+                     weak_factory_.GetWeakPtr(), version),
+      kMaxDmgSize);
+}
+
+void OcbotBrowserUpdater::OnDmgDownloaded(const std::string& version,
+                                           base::FilePath tmp) {
+  DCHECK_CURRENTLY_ON(content::BrowserThread::UI);
+
+  if (tmp.empty()) {
+    LOG(ERROR) << "ocbot browser updater: DMG download failed (net error: "
+               << url_loader_->NetError() << ")";
+    url_loader_.reset();
+    return;
+  }
+
+  url_loader_.reset();
+
+  LOG(INFO) << "ocbot browser updater: DMG download complete, installing v"
+            << version << "...";
+
+  base::FilePath app_path = GetCurrentAppPath();
+  if (app_path.empty()) {
+    LOG(ERROR) << "ocbot browser updater: cannot determine app path";
+    return;
+  }
+
+  // Install on a background thread, then report on UI thread.
+  std::string ver = version;
+  base::ThreadPool::PostTaskAndReplyWithResult(
+      FROM_HERE,
+      {base::MayBlock(), base::TaskPriority::USER_VISIBLE,
+       base::TaskShutdownBehavior::SKIP_ON_SHUTDOWN},
+      base::BindOnce(&InstallFromDmgBlocking, tmp, app_path),
+      base::BindOnce(&OcbotBrowserUpdater::OnInstallComplete,
+                     weak_factory_.GetWeakPtr(), std::move(ver)));
+}
+
+void OcbotBrowserUpdater::OnInstallComplete(const std::string& version,
+                                             bool success) {
+  DCHECK_CURRENTLY_ON(content::BrowserThread::UI);
+
+  if (success) {
+    LOG(INFO) << "ocbot browser updater: v" << version
+              << " installed successfully. UpgradeDetector will prompt "
+              << "the user to relaunch.";
+  } else {
+    LOG(WARNING) << "ocbot browser updater: installation of v" << version
+                 << " failed.";
+  }
+}
+
+std::string OcbotBrowserUpdater::GetRunningVersion() const {
+  @autoreleasepool {
+    NSString* ver = [base::apple::MainBundle()
+        objectForInfoDictionaryKey:@"CFBundleShortVersionString"];
+    if (ver) {
+      return base::SysNSStringToUTF8(ver);
+    }
+  }
+  // Fallback to compiled-in version.
+  return std::string(version_info::GetVersionNumber());
+}
+
+base::FilePath OcbotBrowserUpdater::GetCurrentAppPath() const {
+  @autoreleasepool {
+    NSString* path = [base::apple::MainBundle() bundlePath];
+    if (path) {
+      return base::FilePath(base::SysNSStringToUTF8(path));
+    }
+  }
+  return base::FilePath();
+}
+
+network::mojom::URLLoaderFactory*
+OcbotBrowserUpdater::GetURLLoaderFactory() {
+  auto* manager = SystemNetworkContextManager::GetInstance();
+  if (!manager) {
+    LOG(WARNING) << "ocbot browser updater: SystemNetworkContextManager not "
+                 << "available yet, skipping update check";
+    return nullptr;
+  }
+  return manager->GetURLLoaderFactory();
+}
+
+}  // namespace ocbot
