+RuntimeManager::RuntimeManager() = default;
+
+RuntimeManager::~RuntimeManager() {
+  Stop();
+}
+
+void RuntimeManager::Start() {
+  DCHECK_CURRENTLY_ON(content::BrowserThread::UI);
+
+  // Note: Start() is called from ComponentLoader::AddDefaultComponentExtensions
+  // which already holds a base::ScopedAllowBlocking, so file I/O here is fine.
+
+  if (!LocateRuntime()) {
+    LOG(INFO) << "ocbot runtime: no runtime found, skipping";
+    return;
+  }
+
+  if (!EnsureConfig()) {
+    LOG(ERROR) << "ocbot runtime: failed to set up config";
+    return;
+  }
+
+  LOG(INFO) << "ocbot runtime: starting OpenClaw gateway"
+            << (using_ota_runtime_ ? " (OTA)" : " (embedded)") << "...";
+
+  // Keep the browser process alive while the runtime is running.
+  keep_alive_ = std::make_unique<ScopedKeepAlive>(
+      KeepAliveOrigin::OCBOT_RUNTIME, KeepAliveRestartOption::DISABLED);
+
+  // Delay the initial spawn slightly to let the browser finish startup.
+  content::GetUIThreadTaskRunner({})->PostDelayedTask(
+      FROM_HERE,
+      base::BindOnce(&RuntimeManager::SpawnGateway,
+                      weak_factory_.GetWeakPtr()),
+      kStartDelay);
+}
+
+void RuntimeManager::Stop() {
+  health_check_timer_.Stop();
+  weak_factory_.InvalidateWeakPtrs();
+
+  if (gateway_process_.IsValid()) {
+    LOG(INFO) << "ocbot runtime: stopping OpenClaw gateway (pid="
+              << gateway_process_.Pid() << ")...";
+    gateway_process_.Terminate(/*exit_code=*/0, /*wait=*/false);
+    // Give it a moment to exit gracefully.
+    gateway_process_.WaitForExitWithTimeout(base::Seconds(5), nullptr);
+    gateway_process_.Close();
+  }
+
+  keep_alive_.reset();
+}
+
+bool RuntimeManager::IsRunning() const {
+  if (!gateway_process_.IsValid()) {
+    return false;
+  }
+  // WaitForExitWithTimeout with zero timeout is a non-blocking check.
+  return !gateway_process_.WaitForExitWithTimeout(base::TimeDelta(), nullptr);
+}
+
+bool RuntimeManager::LocateRuntime() {
+  // Initialize OTA runtime directory.
+  ota_runtime_dir_ = GetOtaRuntimeDir();
+
+  // 1. Apply any pending update first.
+  if (!ota_runtime_dir_.empty()) {
+    ApplyPendingUpdate();
+  }
+
+  // 2. Check OTA runtime: runtime/app/current/openclaw.mjs
+  if (!ota_runtime_dir_.empty()) {
+    base::FilePath app_current =
+        ota_runtime_dir_.Append(FILE_PATH_LITERAL("app"))
+            .Append(FILE_PATH_LITERAL("current"));
+    base::FilePath openclaw_entry =
+        app_current.Append(FILE_PATH_LITERAL("openclaw.mjs"));
+
+    if (base::PathExists(openclaw_entry)) {
+      openclaw_dir_ = app_current;
+      using_ota_runtime_ = true;
+      LOG(INFO) << "ocbot runtime: using OTA runtime at " << openclaw_dir_;
+
+      // Node binary still comes from embedded Resources/.
+      if (!LocateEmbeddedRuntime()) {
+        // Can't find node — fall through to full embedded check.
+        using_ota_runtime_ = false;
+        openclaw_dir_ = base::FilePath();
+      } else {
+        return true;
+      }
+    }
+  }
+
+  // 3. Fallback to embedded Resources/openclaw/.
+  return LocateEmbeddedRuntime();
+}
+
+bool RuntimeManager::LocateEmbeddedRuntime() {
+  base::FilePath resources_dir;
+  if (!base::PathService::Get(chrome::DIR_RESOURCES, &resources_dir)) {
+    LOG(WARNING) << "ocbot runtime: cannot resolve DIR_RESOURCES";
+    return false;
+  }
+
+  node_path_ = resources_dir.Append(FILE_PATH_LITERAL("node"));
+
+#if BUILDFLAG(IS_WIN)
+  node_path_ = resources_dir.Append(FILE_PATH_LITERAL("node.exe"));
+#endif
+
+  if (!base::PathExists(node_path_)) {
+    LOG(INFO) << "ocbot runtime: node binary not found at " << node_path_;
+    return false;
+  }
+
+  LOG(INFO) << "ocbot runtime: found node at " << node_path_;
+
+  // If OTA runtime is already set, don't override openclaw_dir_.
+  if (using_ota_runtime_) {
+    return true;
+  }
+
+  openclaw_dir_ = resources_dir.Append(FILE_PATH_LITERAL("openclaw"));
+
+  base::FilePath openclaw_entry =
+      openclaw_dir_.Append(FILE_PATH_LITERAL("openclaw.mjs"));
+  if (!base::PathExists(openclaw_entry)) {
+    LOG(INFO) << "ocbot runtime: openclaw.mjs not found at " << openclaw_entry;
+    return false;
+  }
+
+  LOG(INFO) << "ocbot runtime: found openclaw at " << openclaw_dir_;
+  return true;
+}
+
+bool RuntimeManager::EnsureConfig() {
+  // Determine config directory.
+#if BUILDFLAG(IS_MAC)
+  base::FilePath home_dir;
+  if (!base::PathService::Get(base::DIR_HOME, &home_dir)) {
+    return false;
+  }
+  config_dir_ = home_dir.Append(FILE_PATH_LITERAL("Library"))
+                    .Append(FILE_PATH_LITERAL("Application Support"))
+                    .Append(FILE_PATH_LITERAL("Ocbot"))
+                    .Append(FILE_PATH_LITERAL("openclaw-config"));
+#elif BUILDFLAG(IS_WIN)
+  base::FilePath appdata_dir;
+  if (!base::PathService::Get(base::DIR_ROAMING_APP_DATA, &appdata_dir)) {
+    return false;
+  }
+  config_dir_ = appdata_dir.Append(FILE_PATH_LITERAL("Ocbot"))
+                    .Append(FILE_PATH_LITERAL("openclaw-config"));
+#else
+  base::FilePath home_dir;
+  if (!base::PathService::Get(base::DIR_HOME, &home_dir)) {
+    return false;
+  }
+  config_dir_ = home_dir.Append(FILE_PATH_LITERAL(".config"))
+                    .Append(FILE_PATH_LITERAL("ocbot"))
+                    .Append(FILE_PATH_LITERAL("openclaw-config"));
+#endif
+
+  if (!base::CreateDirectory(config_dir_)) {
+    LOG(ERROR) << "ocbot runtime: failed to create config dir: " << config_dir_;
+    return false;
+  }
+
+  config_file_ = config_dir_.Append(FILE_PATH_LITERAL("openclaw.json"));
+
+  // Only generate default config if it doesn't exist.
+  if (!base::PathExists(config_file_)) {
+    std::string config_json = GenerateDefaultConfig();
+    if (!base::WriteFile(config_file_, config_json)) {
+      LOG(ERROR) << "ocbot runtime: failed to write config: " << config_file_;
+      return false;
+    }
+    LOG(INFO) << "ocbot runtime: generated default config at " << config_file_;
+  }
+
+  return true;
+}
+
+void RuntimeManager::SpawnGateway() {
+  DCHECK_CURRENTLY_ON(content::BrowserThread::UI);
+
+  if (IsRunning()) {
+    LOG(INFO) << "ocbot runtime: gateway already running";
+    return;
+  }
+
+  base::FilePath openclaw_entry =
+      openclaw_dir_.Append(FILE_PATH_LITERAL("openclaw.mjs"));
+
+  base::LaunchOptions options;
+
+  // Set environment variables for OpenClaw.
+  options.environment["OPENCLAW_CONFIG_PATH"] = config_file_.value();
+  options.environment["OPENCLAW_STATE_DIR"] = config_dir_.value();
+  // Force in-process restart on config changes instead of spawning a new
+  // detached process.  RuntimeManager owns the gateway lifecycle, so
+  // process-level respawn must not happen behind its back.
+  options.environment["OPENCLAW_NO_RESPAWN"] = "1";
+
+  // OTA mode: set NODE_PATH so node can find modules in base layer.
+  if (using_ota_runtime_ && !ota_runtime_dir_.empty()) {
+    base::FilePath base_current =
+        ota_runtime_dir_.Append(FILE_PATH_LITERAL("base"))
+            .Append(FILE_PATH_LITERAL("current"))
+            .Append(FILE_PATH_LITERAL("node_modules"));
+    if (base::PathExists(base_current)) {
+      options.environment["NODE_PATH"] = base_current.value();
+      LOG(INFO) << "ocbot runtime: NODE_PATH=" << base_current;
+    }
+  }
+
+#if BUILDFLAG(IS_WIN)
+  // Hide the console window on Windows.
+  options.start_hidden = true;
+#endif
+
+  std::vector<std::string> argv = {
+      node_path_.value(),
+      openclaw_entry.value(),
+      "gateway",
+      "run",
+      "--port",
+      base::NumberToString(kGatewayPort),
+      "--bind",
+      "loopback",
+      "--force",
+  };
+
+  LOG(INFO) << "ocbot runtime: spawning gateway: " << node_path_ << " "
+            << openclaw_entry << " gateway run --port " << kGatewayPort;
+
+  gateway_process_ = base::LaunchProcess(argv, options);
+
+  if (!gateway_process_.IsValid()) {
+    LOG(ERROR) << "ocbot runtime: failed to spawn gateway process";
+    return;
+  }
+
+  LOG(INFO) << "ocbot runtime: gateway started (pid="
+            << gateway_process_.Pid() << ")";
+
+  // Start periodic health checks.
+  consecutive_failures_ = 0;
+  health_check_timer_.Start(
+      FROM_HERE, kHealthCheckInterval,
+      base::BindRepeating(&RuntimeManager::HealthCheck,
+                          weak_factory_.GetWeakPtr()));
+}
+
+void RuntimeManager::HealthCheck() {
+  DCHECK_CURRENTLY_ON(content::BrowserThread::UI);
+
+  // Check if process is still alive first.
+  if (gateway_process_.IsValid() &&
+      gateway_process_.WaitForExitWithTimeout(base::TimeDelta(), nullptr)) {
+    LOG(WARNING) << "ocbot runtime: gateway process exited unexpectedly";
+    gateway_process_.Close();
+    consecutive_failures_ = kMaxFailuresBeforeRestart;
+    OnHealthCheckComplete(false);
+    return;
+  }
+
+  // Do TCP port check on background thread.
+  base::ThreadPool::PostTaskAndReplyWithResult(
+      FROM_HERE,
+      {base::MayBlock(), base::TaskPriority::BEST_EFFORT,
+       base::TaskShutdownBehavior::SKIP_ON_SHUTDOWN},
+      base::BindOnce(&IsPortListening, kGatewayPort),
+      base::BindOnce(&RuntimeManager::OnHealthCheckComplete,
+                      weak_factory_.GetWeakPtr()));
+}
+
+void RuntimeManager::OnHealthCheckComplete(bool alive) {
+  DCHECK_CURRENTLY_ON(content::BrowserThread::UI);
+
+  if (alive) {
+    if (consecutive_failures_ > 0) {
+      LOG(INFO) << "ocbot runtime: gateway recovered";
+    }
+    consecutive_failures_ = 0;
+
+    // If we just applied an update and health check passes, clean up.
+    if (just_applied_update_) {
+      just_applied_update_ = false;
+      LOG(INFO) << "ocbot runtime: OTA update verified, cleaning up old versions";
+      base::ThreadPool::PostTask(
+          FROM_HERE,
+          {base::MayBlock(), base::TaskPriority::BEST_EFFORT,
+           base::TaskShutdownBehavior::SKIP_ON_SHUTDOWN},
+          base::BindOnce(
+              [](RuntimeManager* mgr) { mgr->CleanupOldVersions(); },
+              base::Unretained(this)));
+    }
+    return;
+  }
+
+  consecutive_failures_++;
+  LOG(WARNING) << "ocbot runtime: health check failed ("
+               << consecutive_failures_ << "/" << kMaxFailuresBeforeRestart
+               << ")";
+
+  if (consecutive_failures_ >= kMaxFailuresBeforeRestart) {
+    // If we just applied an update, rollback first.
+    if (just_applied_update_) {
+      LOG(WARNING) << "ocbot runtime: new OTA version failed, rolling back...";
+      just_applied_update_ = false;
+      RevertToPrevious();
+      return;
+    }
+
+    LOG(INFO) << "ocbot runtime: restarting gateway...";
+
+    // Clean up old process if still lingering.
+    if (gateway_process_.IsValid()) {
+      gateway_process_.Terminate(/*exit_code=*/0, /*wait=*/false);
+      gateway_process_.Close();
+    }
+
+    consecutive_failures_ = 0;
+    SpawnGateway();
+  }
+}
+
+bool RuntimeManager::ApplyPendingUpdate() {
+  if (ota_runtime_dir_.empty()) {
+    return false;
+  }
+
+  base::FilePath pending_path =
+      ota_runtime_dir_.Append(FILE_PATH_LITERAL("pending-update.json"));
+
+  if (!base::PathExists(pending_path)) {
+    return false;
+  }
+
+  auto pending = ReadJsonFile(pending_path);
+  if (!pending) {
+    LOG(WARNING) << "ocbot runtime: invalid pending-update.json, removing";
+    base::DeleteFile(pending_path);
+    return false;
+  }
+
+  const std::string* app_version = pending->FindString("appVersion");
+  const std::string* base_version = pending->FindString("baseVersion");
+
+  if (!app_version || !base_version) {
+    LOG(WARNING) << "ocbot runtime: pending-update.json missing versions";
+    base::DeleteFile(pending_path);
+    return false;
+  }
+
+  LOG(INFO) << "ocbot runtime: applying pending update (app="
+            << *app_version << ", base=" << *base_version << ")";
+
+  // Verify version directories exist.
+  base::FilePath app_versions =
+      ota_runtime_dir_.Append(FILE_PATH_LITERAL("app"))
+          .Append(FILE_PATH_LITERAL("versions"));
+  base::FilePath base_versions =
+      ota_runtime_dir_.Append(FILE_PATH_LITERAL("base"))
+          .Append(FILE_PATH_LITERAL("versions"));
+
+  base::FilePath new_app_dir = app_versions.AppendASCII(*app_version);
+  base::FilePath new_base_dir = base_versions.AppendASCII(*base_version);
+
+  if (!base::PathExists(new_app_dir)) {
+    LOG(ERROR) << "ocbot runtime: app version dir missing: " << new_app_dir;
+    base::DeleteFile(pending_path);
+    return false;
+  }
+
+  if (!base::PathExists(new_base_dir)) {
+    LOG(ERROR) << "ocbot runtime: base version dir missing: " << new_base_dir;
+    base::DeleteFile(pending_path);
+    return false;
+  }
+
+#if BUILDFLAG(IS_POSIX)
+  // Swap symlinks.
+  base::FilePath app_current =
+      ota_runtime_dir_.Append(FILE_PATH_LITERAL("app"))
+          .Append(FILE_PATH_LITERAL("current"));
+  base::FilePath app_previous =
+      ota_runtime_dir_.Append(FILE_PATH_LITERAL("app"))
+          .Append(FILE_PATH_LITERAL("previous"));
+  base::FilePath base_current =
+      ota_runtime_dir_.Append(FILE_PATH_LITERAL("base"))
+          .Append(FILE_PATH_LITERAL("current"));
+
+  // Save current as previous (for rollback).
+  base::FilePath old_app_target = ReadSymlink(app_current);
+  if (!old_app_target.empty()) {
+    AtomicSymlinkSwap(app_previous, old_app_target);
+  }
+
+  // Point current to new version.
+  if (!AtomicSymlinkSwap(app_current, new_app_dir)) {
+    LOG(ERROR) << "ocbot runtime: failed to swap app symlink";
+    base::DeleteFile(pending_path);
+    return false;
+  }
+
+  if (!AtomicSymlinkSwap(base_current, new_base_dir)) {
+    LOG(ERROR) << "ocbot runtime: failed to swap base symlink";
+    base::DeleteFile(pending_path);
+    return false;
+  }
+#else
+  // Windows: no symlinks, use a "current-version" marker file instead.
+  // Write version pointers as text files.
+  base::FilePath app_marker =
+      ota_runtime_dir_.Append(FILE_PATH_LITERAL("app"))
+          .Append(FILE_PATH_LITERAL("current-version"));
+  base::FilePath base_marker =
+      ota_runtime_dir_.Append(FILE_PATH_LITERAL("base"))
+          .Append(FILE_PATH_LITERAL("current-version"));
+
+  // Save previous for rollback.
+  std::string old_app_ver;
+  base::ReadFileToString(app_marker, &old_app_ver);
+  if (!old_app_ver.empty()) {
+    base::FilePath prev_marker =
+        ota_runtime_dir_.Append(FILE_PATH_LITERAL("app"))
+            .Append(FILE_PATH_LITERAL("previous-version"));
+    base::WriteFile(prev_marker, old_app_ver);
+  }
+
+  base::WriteFile(app_marker, *app_version);
+  base::WriteFile(base_marker, *base_version);
+#endif
+
+  // Delete pending marker.
+  base::DeleteFile(pending_path);
+
+  // Write update-manifest.json.
+  base::Value::Dict manifest;
+  manifest.Set("appVersion", *app_version);
+  manifest.Set("baseVersion", *base_version);
+  const std::string* version = pending->FindString("version");
+  if (version) {
+    manifest.Set("version", *version);
+  }
+
+  base::FilePath manifest_path =
+      ota_runtime_dir_.Append(FILE_PATH_LITERAL("update-manifest.json"));
+  WriteJsonFile(manifest_path, manifest);
+
+  just_applied_update_ = true;
+
+  LOG(INFO) << "ocbot runtime: update applied (app=" << *app_version
+            << ", base=" << *base_version << ")";
+  return true;
+}
+
+void RuntimeManager::RevertToPrevious() {
+  // Stop current gateway.
+  if (gateway_process_.IsValid()) {
+    gateway_process_.Terminate(/*exit_code=*/0, /*wait=*/false);
+    gateway_process_.WaitForExitWithTimeout(base::Seconds(3), nullptr);
+    gateway_process_.Close();
+  }
+
+#if BUILDFLAG(IS_POSIX)
+  base::FilePath app_current =
+      ota_runtime_dir_.Append(FILE_PATH_LITERAL("app"))
+          .Append(FILE_PATH_LITERAL("current"));
+  base::FilePath app_previous =
+      ota_runtime_dir_.Append(FILE_PATH_LITERAL("app"))
+          .Append(FILE_PATH_LITERAL("previous"));
+
+  base::FilePath prev_target = ReadSymlink(app_previous);
+  if (!prev_target.empty() && base::PathExists(prev_target)) {
+    LOG(INFO) << "ocbot runtime: reverting to previous: " << prev_target;
+    AtomicSymlinkSwap(app_current, prev_target);
+
+    // Try restarting with previous version.
+    openclaw_dir_ = app_current;
+    consecutive_failures_ = 0;
+    SpawnGateway();
+    return;
+  }
+#endif
+
+  // No previous version available — fall back to embedded.
+  LOG(WARNING) << "ocbot runtime: no previous version, falling back to embedded";
+  using_ota_runtime_ = false;
+  openclaw_dir_ = base::FilePath();
+
+  if (LocateEmbeddedRuntime()) {
+    consecutive_failures_ = 0;
+    SpawnGateway();
+  } else {
+    LOG(ERROR) << "ocbot runtime: embedded runtime also unavailable";
+  }
+}
+
+void RuntimeManager::CleanupOldVersions() {
+  if (ota_runtime_dir_.empty()) {
+    return;
+  }
+
+  // For each layer (app, base), keep only current + previous.
+  for (const char* layer : {"app", "base"}) {
+    base::FilePath versions_dir =
+        ota_runtime_dir_.Append(FILE_PATH_LITERAL(layer))
+            .Append(FILE_PATH_LITERAL("versions"));
+
+    if (!base::PathExists(versions_dir)) {
+      continue;
+    }
+
+    // Read current and previous targets.
+    std::set<std::string> keep;
+
+#if BUILDFLAG(IS_POSIX)
+    base::FilePath current_link =
+        ota_runtime_dir_.Append(FILE_PATH_LITERAL(layer))
+            .Append(FILE_PATH_LITERAL("current"));
+    base::FilePath previous_link =
+        ota_runtime_dir_.Append(FILE_PATH_LITERAL(layer))
+            .Append(FILE_PATH_LITERAL("previous"));
+
+    base::FilePath current_target = ReadSymlink(current_link);
+    base::FilePath previous_target = ReadSymlink(previous_link);
+
+    if (!current_target.empty()) {
+      keep.insert(current_target.BaseName().value());
+    }
+    if (!previous_target.empty()) {
+      keep.insert(previous_target.BaseName().value());
+    }
+#else
+    // Windows: read version marker files.
+    base::FilePath current_marker =
+        ota_runtime_dir_.Append(FILE_PATH_LITERAL(layer))
+            .Append(FILE_PATH_LITERAL("current-version"));
+    base::FilePath previous_marker =
+        ota_runtime_dir_.Append(FILE_PATH_LITERAL(layer))
+            .Append(FILE_PATH_LITERAL("previous-version"));
+
+    std::string cur_ver, prev_ver;
+    base::ReadFileToString(current_marker, &cur_ver);
+    base::ReadFileToString(previous_marker, &prev_ver);
+    if (!cur_ver.empty()) keep.insert(cur_ver);
+    if (!prev_ver.empty()) keep.insert(prev_ver);
+#endif
+
+    // Enumerate version directories and delete old ones.
+    base::FileEnumerator enumerator(versions_dir, /*recursive=*/false,
+                                    base::FileEnumerator::DIRECTORIES);
+    for (base::FilePath dir = enumerator.Next(); !dir.empty();
+         dir = enumerator.Next()) {
+      std::string name = dir.BaseName().value();
+      if (keep.find(name) == keep.end()) {
+        LOG(INFO) << "ocbot runtime: removing old version: " << dir;
+        base::DeletePathRecursively(dir);
+      }
+    }
+  }
+}
+
+base::FilePath RuntimeManager::GetOtaRuntimeDir() const {
+#if BUILDFLAG(IS_MAC)
+  base::FilePath home_dir;
+  if (!base::PathService::Get(base::DIR_HOME, &home_dir)) {
+    return base::FilePath();
+  }
+  return home_dir.Append(FILE_PATH_LITERAL("Library"))
+      .Append(FILE_PATH_LITERAL("Application Support"))
+      .Append(FILE_PATH_LITERAL("Ocbot"))
+      .Append(FILE_PATH_LITERAL("runtime"));
+#elif BUILDFLAG(IS_WIN)
+  base::FilePath appdata_dir;
+  if (!base::PathService::Get(base::DIR_ROAMING_APP_DATA, &appdata_dir)) {
+    return base::FilePath();
+  }
+  return appdata_dir.Append(FILE_PATH_LITERAL("Ocbot"))
+      .Append(FILE_PATH_LITERAL("runtime"));
+#else
+  base::FilePath home_dir;
+  if (!base::PathService::Get(base::DIR_HOME, &home_dir)) {
+    return base::FilePath();
+  }
+  return home_dir.Append(FILE_PATH_LITERAL(".config"))
+      .Append(FILE_PATH_LITERAL("ocbot"))
+      .Append(FILE_PATH_LITERAL("runtime"));
+#endif
+}
