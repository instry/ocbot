+#if BUILDFLAG(IS_POSIX)
+// Atomically swap a symlink: create tmp link, then rename over target.
+bool AtomicSymlinkSwap(const base::FilePath& link_path,
+                       const base::FilePath& target) {
+  base::FilePath tmp_link =
+      link_path.DirName().Append(link_path.BaseName().value() + ".tmp");
+  // Remove stale tmp if exists.
+  base::DeleteFile(tmp_link);
+
+  if (symlink(target.value().c_str(), tmp_link.value().c_str()) != 0) {
+    LOG(ERROR) << "ocbot runtime: symlink create failed for " << tmp_link;
+    return false;
+  }
+  if (rename(tmp_link.value().c_str(), link_path.value().c_str()) != 0) {
+    LOG(ERROR) << "ocbot runtime: rename failed for " << link_path;
+    base::DeleteFile(tmp_link);
+    return false;
+  }
+  return true;
+}
+
+// Read symlink target.
+base::FilePath ReadSymlink(const base::FilePath& path) {
+  base::FilePath target;
+  if (!base::ReadSymbolicLink(path, &target)) {
+    return base::FilePath();
+  }
+  return target;
+}
+#endif
