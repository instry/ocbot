+#include "chrome/browser/ui/views/tabs/ocbot_tab_strip_button.h"
+
+#include "chrome/browser/ui/views/tabs/tab_strip_control_button.h"
+#include "chrome/grit/chrome_unscaled_resources.h"
+#include "ui/base/metadata/metadata_impl_macros.h"
+#include "ui/base/models/image_model.h"
+#include "ui/base/resource/resource_bundle.h"
+#include "ui/views/accessibility/view_accessibility.h"
+#include "ui/views/animation/ink_drop.h"
+#include "ui/views/animation/ink_drop_state.h"
+#include "ui/views/controls/label.h"
+#include "ui/views/style/typography.h"
+#include "ui/views/view_class_properties.h"
+
+namespace {
+constexpr int kLabelLeftMargin = 4;
+constexpr int kLabelRightMargin = 8;
+}  // namespace
+
+OcbotTabStripButton::OcbotTabStripButton(TabStripController* controller,
+                                         PressedCallback callback)
+    : TabStripControlButton(controller,
+                            std::move(callback),
+                            std::u16string(),
+                            Edge::kNone,
+                            Edge::kNone) {
+  // Use PNG product logo instead of vector icon.
+  const gfx::ImageSkia* logo =
+      ui::ResourceBundle::GetSharedInstance().GetImageSkiaNamed(
+          IDR_PRODUCT_LOGO_24_SHORTCUTS);
+  if (logo) {
+    SetImageModel(views::Button::STATE_NORMAL,
+                  ui::ImageModel::FromImageSkia(*logo));
+  }
+
+  // Style the label for when it becomes visible (panel open state).
+  SetLabelStyle(views::style::STYLE_BODY_3_EMPHASIS);
+  label()->SetElideBehavior(gfx::ElideBehavior::NO_ELIDE);
+
+  SetTooltipText(u"Ocbot AI Assistant");
+  GetViewAccessibility().SetName(u"Ocbot AI Assistant");
+}
+
+OcbotTabStripButton::~OcbotTabStripButton() = default;
+
+void OcbotTabStripButton::SetPanelOpen(bool open) {
+  if (panel_open_ == open) {
+    return;
+  }
+  panel_open_ = open;
+
+  if (open) {
+    // Expand: show "Ocbot" label next to icon (pill shape).
+    SetText(u"Ocbot");
+    label()->SetProperty(
+        views::kMarginsKey,
+        gfx::Insets::TLBR(0, kLabelLeftMargin, 0, kLabelRightMargin));
+  } else {
+    // Collapse: icon only.
+    SetText(u"");
+    label()->SetProperty(views::kMarginsKey, gfx::Insets());
+  }
+
+  // Show ink drop highlight when panel is open.
+  auto* ink_drop = views::InkDrop::Get(this);
+  if (ink_drop) {
+    ink_drop->GetInkDrop()->AnimateToState(
+        open ? views::InkDropState::ACTIVATED
+             : views::InkDropState::DEACTIVATED);
+  }
+
+  PreferredSizeChanged();
+}
+
+void OcbotTabStripButton::NotifyClick(const ui::Event& event) {
+  // Toggle visual state on click. The callback will toggle the side panel.
+  SetPanelOpen(!panel_open_);
+  TabStripControlButton::NotifyClick(event);
+}
+
+void OcbotTabStripButton::UpdateColors() {
+  TabStripControlButton::UpdateColors();
+}
+
+BEGIN_METADATA(OcbotTabStripButton)
+END_METADATA
