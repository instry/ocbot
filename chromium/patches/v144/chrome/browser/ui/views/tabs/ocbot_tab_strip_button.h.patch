+#ifndef CHROME_BROWSER_UI_VIEWS_TABS_OCBOT_TAB_STRIP_BUTTON_H_
+#define CHROME_BROWSER_UI_VIEWS_TABS_OCBOT_TAB_STRIP_BUTTON_H_
+
+#include "chrome/browser/ui/views/tabs/tab_strip_control_button.h"
+#include "ui/base/metadata/metadata_header_macros.h"
+
+class TabStripController;
+
+// Button in the tab strip region that toggles the Ocbot side panel.
+// Two states:
+//   - Closed: logo + "O" (brand purple)
+//   - Open: logo + "C" (brand purple, highlighted background)
+class OcbotTabStripButton : public TabStripControlButton {
+  METADATA_HEADER(OcbotTabStripButton, TabStripControlButton)
+
+ public:
+  OcbotTabStripButton(TabStripController* controller,
+                      PressedCallback callback);
+  OcbotTabStripButton(const OcbotTabStripButton&) = delete;
+  OcbotTabStripButton& operator=(const OcbotTabStripButton&) = delete;
+  ~OcbotTabStripButton() override;
+
+  void SetPanelOpen(bool open);
+  bool IsPanelOpen() const { return panel_open_; }
+
+ protected:
+  void UpdateColors() override;
+  void NotifyClick(const ui::Event& event) override;
+  int GetCornerRadius() const override;
+  gfx::Size CalculatePreferredSize(
+      const views::SizeBounds& available_size) const override;
+  ui::Cursor GetCursor(const ui::MouseEvent& event) override;
+  void PaintButtonContents(gfx::Canvas* canvas) override;
+
+ private:
+  bool panel_open_ = false;
+};
+
+#endif  // CHROME_BROWSER_UI_VIEWS_TABS_OCBOT_TAB_STRIP_BUTTON_H_
