diff --git a/chrome/browser/ui/ocbot/ocbot_url_handler.cc b/chrome/browser/ui/ocbot/ocbot_url_handler.cc
new file mode 100644
index 0000000000000000000000000000000000000000..e49ef791cd115d2607b97624f62ff552079ee155
--- /dev/null
+++ b/chrome/browser/ui/ocbot/ocbot_url_handler.cc
@@ -0,0 +1,102 @@
+#include "chrome/browser/ui/ocbot/ocbot_url_handler.h"
+
+#include "chrome/browser/ui/ocbot/ocbot_constants.h"
+#include "chrome/browser/ocbot/skill_installer.h"
+#include "chrome/common/url_constants.h"
+#include "extensions/common/constants.h"
+#include "url/gurl.h"
+
+namespace ocbot {
+
+bool HandleOcURL(GURL* url, content::BrowserContext* browser_context) {
+  if (!url->SchemeIs(chrome::kOcScheme)) {
+    return false;
+  }
+
+  // oc://home           -> chrome-extension://<id>/home.html#/home
+  // oc://home/skills    -> chrome-extension://<id>/home.html#/skills
+  // oc://home/skills?id=xxx -> chrome-extension://<id>/home.html#/skills?id=xxx
+  if (url->host() != chrome::kOcHomeHost) {
+    return false;
+  }
+
+  // Extract path after host: "/skills" -> "skills", "/" -> ""
+  std::string path(url->path());
+  if (!path.empty() && path[0] == '/') {
+    path = path.substr(1);
+  }
+  if (!path.empty() && path.back() == '/') {
+    path.pop_back();
+  }
+  if (path.empty()) {
+    path = "home";
+  }
+
+  // Preserve query string
+  if (url->has_query()) {
+    path += "?" + std::string(url->query());
+    std::string query(url->query());
+    if (query.find("action=install") != std::string::npos) {
+      std::string slug;
+      std::string version;
+      size_t sp = query.find("slug=");
+      if (sp != std::string::npos) {
+        size_t sv = sp + 5;
+        size_t se = query.find('&', sv);
+        slug = query.substr(sv, se == std::string::npos ? std::string::npos : se - sv);
+      }
+      size_t vp = query.find("version=");
+      if (vp != std::string::npos) {
+        size_t vv = vp + 8;
+        size_t ve = query.find('&', vv);
+        version = query.substr(vv, ve == std::string::npos ? std::string::npos : ve - vv);
+      }
+      ocbot::InstallSkillBySlug(browser_context, slug, version);
+    }
+  }
+
+  *url = GURL(std::string(extensions::kExtensionScheme) + "://" +
+              kOcbotExtensionId + "/home.html#/" + path);
+  return true;
+}
+
+bool HandleOcURLReverse(GURL* url, content::BrowserContext* browser_context) {
+  if (!url->SchemeIs(extensions::kExtensionScheme) ||
+      url->host() != kOcbotExtensionId ||
+      !url->path().starts_with("/home.html")) {
+    return false;
+  }
+
+  // chrome-extension://<id>/home.html#/skills?id=xxx -> oc://home/skills?id=xxx
+  // chrome-extension://<id>/home.html#/home -> oc://home
+  std::string ref(url->ref());
+  if (ref.starts_with("/")) {
+    ref = ref.substr(1);
+  }
+
+  // Split fragment at '?' to separate path and query
+  std::string frag_path;
+  std::string frag_query;
+  auto qpos = ref.find('?');
+  if (qpos != std::string::npos) {
+    frag_path = ref.substr(0, qpos);
+    frag_query = ref.substr(qpos);  // includes '?'
+  } else {
+    frag_path = ref;
+  }
+
+  // oc://home is the root; other pages are oc://home/<page>
+  std::string oc_url = std::string(chrome::kOcScheme) + "://" +
+                        chrome::kOcHomeHost;
+  if (!frag_path.empty() && frag_path != "home") {
+    oc_url += "/" + frag_path;
+  }
+  if (!frag_query.empty()) {
+    oc_url += frag_query;
+  }
+
+  *url = GURL(oc_url);
+  return true;
+}
+
+}  // namespace ocbot
