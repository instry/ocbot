+// Build AX tree recursively, returns a base::Value::Dict.
+base::Value::Dict BuildAXTree(AXUIElementRef element,
+                              int& node_id,
+                              int depth,
+                              int max_depth) {
+  base::Value::Dict node;
+  node.Set("nodeId", node_id++);
+
+  CFTypeRef role_ref = nullptr;
+  AXUIElementCopyAttributeValue(element, kAXRoleAttribute, &role_ref);
+  if (role_ref) {
+    NSString* role = (__bridge NSString*)role_ref;
+    // Map AX roles to simpler names
+    static NSDictionary* roleMap = @{
+      @"AXButton" : @"button",
+      @"AXTextField" : @"textfield",
+      @"AXStaticText" : @"text",
+      @"AXImage" : @"image",
+      @"AXCheckBox" : @"checkbox",
+      @"AXRadioButton" : @"radio",
+      @"AXPopUpButton" : @"popup",
+      @"AXComboBox" : @"combobox",
+      @"AXSlider" : @"slider",
+      @"AXTextArea" : @"textarea",
+      @"AXLink" : @"link",
+      @"AXList" : @"list",
+      @"AXTable" : @"table",
+      @"AXRow" : @"row",
+      @"AXCell" : @"cell",
+      @"AXGroup" : @"group",
+      @"AXWindow" : @"window",
+      @"AXToolbar" : @"toolbar",
+      @"AXMenuBar" : @"menubar",
+      @"AXMenu" : @"menu",
+      @"AXMenuItem" : @"menuitem",
+      @"AXTabGroup" : @"tabgroup",
+      @"AXScrollArea" : @"scrollarea",
+    };
+    NSString* mapped = roleMap[role] ?: role;
+    node.Set("role", base::SysNSStringToUTF8(mapped));
+    CFRelease(role_ref);
+  }
+
+  CFTypeRef title_ref = nullptr;
+  AXUIElementCopyAttributeValue(element, kAXTitleAttribute, &title_ref);
+  if (title_ref) {
+    node.Set("name", base::SysNSStringToUTF8((__bridge NSString*)title_ref));
+    CFRelease(title_ref);
+  }
+
+  CFTypeRef value_ref = nullptr;
+  AXUIElementCopyAttributeValue(element, kAXValueAttribute, &value_ref);
+  if (value_ref && CFGetTypeID(value_ref) == CFStringGetTypeID()) {
+    node.Set("value",
+             base::SysNSStringToUTF8((__bridge NSString*)value_ref));
+    CFRelease(value_ref);
+  } else if (value_ref) {
+    CFRelease(value_ref);
+  }
+
+  // Position and size
+  CFTypeRef pos_ref = nullptr;
+  AXUIElementCopyAttributeValue(element, kAXPositionAttribute, &pos_ref);
+  if (pos_ref) {
+    CGPoint pt;
+    if (AXValueGetValue((AXValueRef)pos_ref, kAXValueTypeCGPoint, &pt)) {
+      node.Set("x", static_cast<int>(pt.x));
+      node.Set("y", static_cast<int>(pt.y));
+    }
+    CFRelease(pos_ref);
+  }
+
+  CFTypeRef size_ref = nullptr;
+  AXUIElementCopyAttributeValue(element, kAXSizeAttribute, &size_ref);
+  if (size_ref) {
+    CGSize sz;
+    if (AXValueGetValue((AXValueRef)size_ref, kAXValueTypeCGSize, &sz)) {
+      node.Set("width", static_cast<int>(sz.width));
+      node.Set("height", static_cast<int>(sz.height));
+    }
+    CFRelease(size_ref);
+  }
+
+  // Children
+  if (depth < max_depth) {
+    CFTypeRef children_ref = nullptr;
+    AXUIElementCopyAttributeValue(element, kAXChildrenAttribute,
+                                  &children_ref);
+    if (children_ref && CFGetTypeID(children_ref) == CFArrayGetTypeID()) {
+      CFArrayRef children = (CFArrayRef)children_ref;
+      CFIndex count = CFArrayGetCount(children);
+      base::Value::List child_list;
+      for (CFIndex i = 0; i < count && i < 200; i++) {
+        AXUIElementRef child =
+            (AXUIElementRef)CFArrayGetValueAtIndex(children, i);
+        child_list.Append(BuildAXTree(child, node_id, depth + 1, max_depth));
+      }
+      if (!child_list.empty()) {
+        node.Set("children", std::move(child_list));
+      }
+    }
+    if (children_ref) {
+      CFRelease(children_ref);
+    }
+  }
+
+  return node;
+}
