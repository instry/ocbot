+// --- runAppleScript ---
+
+ExtensionFunction::ResponseAction OcbotRunAppleScriptFunction::Run() {
+  auto params = api::ocbot::RunAppleScript::Params::Create(args());
+  if (!params) {
+    return RespondNow(Error("Invalid parameters"));
+  }
+
+  NSString* source = base::SysUTF8ToNSString(params->script);
+  NSAppleScript* script = [[NSAppleScript alloc] initWithSource:source];
+  NSDictionary* error_info = nil;
+  NSAppleEventDescriptor* result = [script executeAndReturnError:&error_info];
+
+  base::Value::Dict dict;
+  if (result) {
+    dict.Set("result", base::SysNSStringToUTF8([result stringValue] ?: @""));
+  } else {
+    NSString* err_msg = error_info[NSAppleScriptErrorMessage] ?: @"Unknown error";
+    return RespondNow(Error(base::SysNSStringToUTF8(err_msg)));
+  }
+  return RespondNow(WithArguments(std::move(dict)));
+}
+
+// --- getDesktopTree ---
+
+ExtensionFunction::ResponseAction OcbotGetDesktopTreeFunction::Run() {
+  auto params = api::ocbot::GetDesktopTree::Params::Create(args());
+  if (!params) {
+    return RespondNow(Error("Invalid parameters"));
+  }
+
+  pid_t pid = params->pid ? static_cast<pid_t>(*params->pid) : 0;
+
+  if (pid == 0) {
+    NSRunningApplication* front =
+        [[NSWorkspace sharedWorkspace] frontmostApplication];
+    if (!front) {
+      return RespondNow(Error("No frontmost application"));
+    }
+    pid = front.processIdentifier;
+  }
+
+  NSRunningApplication* app =
+      [NSRunningApplication runningApplicationWithProcessIdentifier:pid];
+  if (!app) {
+    return RespondNow(Error("Application not found"));
+  }
+
+  AXUIElementRef ax_app = AXUIElementCreateApplication(pid);
+  int node_id = 1;
+  base::Value::Dict tree = BuildAXTree(ax_app, node_id, 0, 10);
+  CFRelease(ax_app);
+
+  base::Value::Dict result;
+  result.Set("appName", base::SysNSStringToUTF8(app.localizedName ?: @""));
+  result.Set("pid", static_cast<int>(pid));
+  result.Set("root", std::move(tree));
+  return RespondNow(WithArguments(std::move(result)));
+}
+
+// --- listApps ---
+
+ExtensionFunction::ResponseAction OcbotListAppsFunction::Run() {
+  NSArray<NSRunningApplication*>* apps =
+      [[NSWorkspace sharedWorkspace] runningApplications];
+  NSRunningApplication* front =
+      [[NSWorkspace sharedWorkspace] frontmostApplication];
+
+  base::Value::List list;
+  for (NSRunningApplication* app in apps) {
+    if (app.activationPolicy != NSApplicationActivationPolicyRegular) {
+      continue;
+    }
+    base::Value::Dict info;
+    info.Set("name", base::SysNSStringToUTF8(app.localizedName ?: @""));
+    info.Set("pid", static_cast<int>(app.processIdentifier));
+    info.Set("bundleId",
+             base::SysNSStringToUTF8(app.bundleIdentifier ?: @""));
+    info.Set("frontmost", app == front);
+    list.Append(std::move(info));
+  }
+  return RespondNow(WithArguments(std::move(list)));
+}
