+// Encode CGImage as base64 JPEG data URL, optionally downscaling.
+std::string EncodeCGImageAsDataUrl(CGImageRef image, int max_width) {
+  size_t w = CGImageGetWidth(image);
+  size_t h = CGImageGetHeight(image);
+
+  if (max_width > 0 && static_cast<int>(w) > max_width) {
+    double scale = static_cast<double>(max_width) / w;
+    w = max_width;
+    h = static_cast<size_t>(h * scale);
+  }
+
+  NSBitmapImageRep* rep = [[NSBitmapImageRep alloc]
+      initWithCGImage:image];
+  if (max_width > 0) {
+    NSImage* scaled = [[NSImage alloc] initWithSize:NSMakeSize(w, h)];
+    [scaled lockFocus];
+    [[NSGraphicsContext currentContext]
+        setImageInterpolation:NSImageInterpolationHigh];
+    [rep drawInRect:NSMakeRect(0, 0, w, h)];
+    [scaled unlockFocus];
+    NSData* tiffData = [scaled TIFFRepresentation];
+    rep = [[NSBitmapImageRep alloc] initWithData:tiffData];
+  }
+
+  NSDictionary* props = @{NSImageCompressionFactor : @0.7};
+  NSData* jpeg = [rep representationUsingType:NSBitmapImageFileTypeJPEG
+                                   properties:props];
+  std::string raw(static_cast<const char*>(jpeg.bytes), jpeg.length);
+  std::string b64 = base::Base64Encode(raw);
+  return "data:image/jpeg;base64," + b64;
+}
