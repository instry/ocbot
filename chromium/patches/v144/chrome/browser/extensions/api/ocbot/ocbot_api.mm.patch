+// --- runCommand ---
+
+ExtensionFunction::ResponseAction OcbotRunCommandFunction::Run() {
+  auto params = api::ocbot::RunCommand::Params::Create(args());
+  if (!params) {
+    return RespondNow(Error("Invalid parameters"));
+  }
+
+  if (IsCommandBlocked(params->command)) {
+    return RespondNow(Error("Command blocked for safety"));
+  }
+
+  int timeout_ms = params->timeout ? *params->timeout : 30000;
+  std::string command = params->command;
+  std::string cwd = params->cwd ? *params->cwd : "";
+
+  // Run on thread pool to avoid blocking UI.
+  AddRef();  // prevent destroy while async task runs
+
+  auto task_runner = base::ThreadPool::CreateTaskRunner(
+      {base::MayBlock(), base::TaskShutdownBehavior::SKIP_ON_SHUTDOWN});
+
+  task_runner->PostTask(
+      FROM_HERE,
+      base::BindOnce(&OcbotRunCommandFunction::RunCommandOnThreadPool,
+                     base::Unretained(this), command, cwd, timeout_ms));
+
+  return RespondLater();
+}
+
+void OcbotRunCommandFunction::RunCommandOnThreadPool(
+    std::string command,
+    std::string cwd,
+    int timeout_ms) {
+  NSTask* task = [[NSTask alloc] init];
+  [task setLaunchPath:@"/bin/zsh"];
+  [task setArguments:@[@"-c", base::SysUTF8ToNSString(command)]];
+
+  if (!cwd.empty()) {
+    [task setCurrentDirectoryPath:base::SysUTF8ToNSString(cwd)];
+  }
+
+  NSPipe* stdout_pipe = [NSPipe pipe];
+  NSPipe* stderr_pipe = [NSPipe pipe];
+  [task setStandardOutput:stdout_pipe];
+  [task setStandardError:stderr_pipe];
+
+  @try {
+    [task launch];
+  } @catch (NSException* e) {
+    base::Value::Dict result;
+    result.Set("stdout", "");
+    result.Set("stderr", base::SysNSStringToUTF8([e reason]));
+    result.Set("exitCode", -1);
+    Respond(WithArguments(std::move(result)));
+    Release();
+    return;
+  }
+
+  // Timeout — use a separate dispatch to terminate if still running
+  NSTask* __block task_ref = task;
+  dispatch_after(
+      dispatch_time(DISPATCH_TIME_NOW, timeout_ms * NSEC_PER_MSEC),
+      dispatch_get_global_queue(DISPATCH_QUEUE_PRIORITY_DEFAULT, 0),
+      ^{
+        if ([task_ref isRunning]) {
+          [task_ref terminate];
+        }
+      });
+
+  [task waitUntilExit];
+
+  NSData* stdout_data =
+      [[stdout_pipe fileHandleForReading] readDataToEndOfFile];
+  NSData* stderr_data =
+      [[stderr_pipe fileHandleForReading] readDataToEndOfFile];
+
+  std::string stdout_str(
+      static_cast<const char*>(stdout_data.bytes), stdout_data.length);
+  std::string stderr_str(
+      static_cast<const char*>(stderr_data.bytes), stderr_data.length);
+
+  base::Value::Dict result;
+  result.Set("stdout", stdout_str);
+  result.Set("stderr", stderr_str);
+  result.Set("exitCode", [task terminationStatus]);
+  Respond(WithArguments(std::move(result)));
+  Release();
+}
