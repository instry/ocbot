+// Map CGKeyCode from key name string.
+CGKeyCode KeyCodeFromName(const std::string& name) {
+  static const base::NoDestructor<std::map<std::string, CGKeyCode>> kMap({
+      {"Return", kVK_Return},
+      {"Enter", kVK_Return},
+      {"Tab", kVK_Tab},
+      {"Space", kVK_Space},
+      {"Escape", kVK_Escape},
+      {"Delete", kVK_Delete},
+      {"ForwardDelete", kVK_ForwardDelete},
+      {"Backspace", kVK_Delete},
+      {"UpArrow", kVK_UpArrow},
+      {"DownArrow", kVK_DownArrow},
+      {"LeftArrow", kVK_LeftArrow},
+      {"RightArrow", kVK_RightArrow},
+      {"Home", kVK_Home},
+      {"End", kVK_End},
+      {"PageUp", kVK_PageUp},
+      {"PageDown", kVK_PageDown},
+      {"F1", kVK_F1},
+      {"F2", kVK_F2},
+      {"F3", kVK_F3},
+      {"F4", kVK_F4},
+      {"F5", kVK_F5},
+      {"F6", kVK_F6},
+      {"F7", kVK_F7},
+      {"F8", kVK_F8},
+      {"F9", kVK_F9},
+      {"F10", kVK_F10},
+      {"F11", kVK_F11},
+      {"F12", kVK_F12},
+      {"a", kVK_ANSI_A}, {"b", kVK_ANSI_B}, {"c", kVK_ANSI_C},
+      {"d", kVK_ANSI_D}, {"e", kVK_ANSI_E}, {"f", kVK_ANSI_F},
+      {"g", kVK_ANSI_G}, {"h", kVK_ANSI_H}, {"i", kVK_ANSI_I},
+      {"j", kVK_ANSI_J}, {"k", kVK_ANSI_K}, {"l", kVK_ANSI_L},
+      {"m", kVK_ANSI_M}, {"n", kVK_ANSI_N}, {"o", kVK_ANSI_O},
+      {"p", kVK_ANSI_P}, {"q", kVK_ANSI_Q}, {"r", kVK_ANSI_R},
+      {"s", kVK_ANSI_S}, {"t", kVK_ANSI_T}, {"u", kVK_ANSI_U},
+      {"v", kVK_ANSI_V}, {"w", kVK_ANSI_W}, {"x", kVK_ANSI_X},
+      {"y", kVK_ANSI_Y}, {"z", kVK_ANSI_Z},
+      {"0", kVK_ANSI_0}, {"1", kVK_ANSI_1}, {"2", kVK_ANSI_2},
+      {"3", kVK_ANSI_3}, {"4", kVK_ANSI_4}, {"5", kVK_ANSI_5},
+      {"6", kVK_ANSI_6}, {"7", kVK_ANSI_7}, {"8", kVK_ANSI_8},
+      {"9", kVK_ANSI_9},
+  });
+  auto it = kMap->find(name);
+  return it != kMap->end() ? it->second : 0;
+}
