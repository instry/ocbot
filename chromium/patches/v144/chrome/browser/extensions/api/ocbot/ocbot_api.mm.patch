+// --- getActiveApp ---
+
+ExtensionFunction::ResponseAction OcbotGetActiveAppFunction::Run() {
+  NSRunningApplication* front =
+      [[NSWorkspace sharedWorkspace] frontmostApplication];
+  if (!front) {
+    return RespondNow(Error("No frontmost application"));
+  }
+
+  base::Value::Dict info;
+  info.Set("name", base::SysNSStringToUTF8(front.localizedName ?: @""));
+  info.Set("pid", static_cast<int>(front.processIdentifier));
+  info.Set("bundleId",
+           base::SysNSStringToUTF8(front.bundleIdentifier ?: @""));
+  info.Set("frontmost", true);
+  return RespondNow(WithArguments(std::move(info)));
+}
