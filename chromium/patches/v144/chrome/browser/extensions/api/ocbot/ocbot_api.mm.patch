+// --- captureScreen ---
+
+ExtensionFunction::ResponseAction OcbotCaptureScreenFunction::Run() {
+  auto params = api::ocbot::CaptureScreen::Params::Create(args());
+  if (!params) {
+    return RespondNow(Error("Invalid parameters"));
+  }
+
+  int max_width = params->max_width ? *params->max_width : 0;
+
+  CGImageRef image = CGWindowListCreateImage(
+      CGRectInfinite, kCGWindowListOptionOnScreenOnly, kCGNullWindowID,
+      kCGWindowImageDefault);
+  if (!image) {
+    return RespondNow(Error("Failed to capture screen"));
+  }
+
+  base::Value::Dict result;
+  result.Set("dataUrl", EncodeCGImageAsDataUrl(image, max_width));
+  result.Set("width", static_cast<int>(CGImageGetWidth(image)));
+  result.Set("height", static_cast<int>(CGImageGetHeight(image)));
+  CGImageRelease(image);
+  return RespondNow(WithArguments(std::move(result)));
+}
+
+// --- captureWindow ---
+
+ExtensionFunction::ResponseAction OcbotCaptureWindowFunction::Run() {
+  auto params = api::ocbot::CaptureWindow::Params::Create(args());
+  if (!params) {
+    return RespondNow(Error("Invalid parameters"));
+  }
+
+  int max_width = params->max_width ? *params->max_width : 0;
+  pid_t pid = static_cast<pid_t>(params->pid);
+
+  // Find window ID for the given PID
+  CFArrayRef window_list = CGWindowListCopyWindowInfo(
+      kCGWindowListOptionOnScreenOnly | kCGWindowListExcludeDesktopElements,
+      kCGNullWindowID);
+  CGWindowID target_wid = 0;
+  if (window_list) {
+    for (CFIndex i = 0; i < CFArrayGetCount(window_list); i++) {
+      CFDictionaryRef info =
+          (CFDictionaryRef)CFArrayGetValueAtIndex(window_list, i);
+      CFNumberRef pid_ref =
+          (CFNumberRef)CFDictionaryGetValue(info, kCGWindowOwnerPID);
+      int wnd_pid = 0;
+      CFNumberGetValue(pid_ref, kCFNumberIntType, &wnd_pid);
+      if (wnd_pid == pid) {
+        CFNumberRef wid_ref =
+            (CFNumberRef)CFDictionaryGetValue(info, kCGWindowNumber);
+        CFNumberGetValue(wid_ref, kCFNumberIntType, &target_wid);
+        break;
+      }
+    }
+    CFRelease(window_list);
+  }
+
+  if (target_wid == 0) {
+    return RespondNow(Error("Window not found for PID"));
+  }
+
+  CGImageRef image = CGWindowListCreateImage(
+      CGRectNull, kCGWindowListOptionIncludingWindow, target_wid,
+      kCGWindowImageBoundsIgnoreFraming);
+  if (!image) {
+    return RespondNow(Error("Failed to capture window"));
+  }
+
+  base::Value::Dict result;
+  result.Set("dataUrl", EncodeCGImageAsDataUrl(image, max_width));
+  result.Set("width", static_cast<int>(CGImageGetWidth(image)));
+  result.Set("height", static_cast<int>(CGImageGetHeight(image)));
+  CGImageRelease(image);
+  return RespondNow(WithArguments(std::move(result)));
+}
