+// --- readFile ---
+
+ExtensionFunction::ResponseAction OcbotReadFileFunction::Run() {
+  auto params = api::ocbot::ReadFile::Params::Create(args());
+  if (!params) {
+    return RespondNow(Error("Invalid parameters"));
+  }
+
+  NSString* path = base::SysUTF8ToNSString(params->path);
+  NSError* error = nil;
+  NSString* content = [NSString stringWithContentsOfFile:path
+                                                encoding:NSUTF8StringEncoding
+                                                   error:&error];
+  if (error) {
+    return RespondNow(
+        Error("Failed to read file: " +
+              base::SysNSStringToUTF8([error localizedDescription])));
+  }
+  return RespondNow(
+      WithArguments(base::SysNSStringToUTF8(content ?: @"")));
+}
+
+// --- writeFile ---
+
+ExtensionFunction::ResponseAction OcbotWriteFileFunction::Run() {
+  auto params = api::ocbot::WriteFile::Params::Create(args());
+  if (!params) {
+    return RespondNow(Error("Invalid parameters"));
+  }
+
+  NSString* path = base::SysUTF8ToNSString(params->path);
+  NSString* content = base::SysUTF8ToNSString(params->content);
+  NSError* error = nil;
+  [content writeToFile:path
+            atomically:YES
+              encoding:NSUTF8StringEncoding
+                 error:&error];
+  if (error) {
+    return RespondNow(
+        Error("Failed to write file: " +
+              base::SysNSStringToUTF8([error localizedDescription])));
+  }
+  return RespondNow(NoArguments());
+}
+
+// --- listDir ---
+
+ExtensionFunction::ResponseAction OcbotListDirFunction::Run() {
+  auto params = api::ocbot::ListDir::Params::Create(args());
+  if (!params) {
+    return RespondNow(Error("Invalid parameters"));
+  }
+
+  NSString* path = base::SysUTF8ToNSString(params->path);
+  NSFileManager* fm = [NSFileManager defaultManager];
+  NSError* error = nil;
+  NSArray<NSString*>* items =
+      [fm contentsOfDirectoryAtPath:path error:&error];
+  if (error) {
+    return RespondNow(
+        Error("Failed to list directory: " +
+              base::SysNSStringToUTF8([error localizedDescription])));
+  }
+
+  base::Value::List list;
+  for (NSString* item in items) {
+    NSString* full = [path stringByAppendingPathComponent:item];
+    NSDictionary* attrs = [fm attributesOfItemAtPath:full error:nil];
+    base::Value::Dict entry;
+    entry.Set("name", base::SysNSStringToUTF8(item));
+    NSString* file_type = attrs[NSFileType];
+    if ([file_type isEqualToString:NSFileTypeDirectory]) {
+      entry.Set("type", "directory");
+    } else {
+      entry.Set("type", "file");
+    }
+    entry.Set("size",
+              static_cast<double>([attrs[NSFileSize] unsignedLongLongValue]));
+    list.Append(std::move(entry));
+  }
+  return RespondNow(WithArguments(std::move(list)));
+}
