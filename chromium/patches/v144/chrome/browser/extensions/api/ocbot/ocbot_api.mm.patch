+// Check if a shell command contains dangerous patterns.
+bool IsCommandBlocked(const std::string& cmd) {
+  static const base::NoDestructor<std::vector<std::string>> kBlocked({
+      "rm -rf /", "sudo ", "mkfs", "dd if=", "> /dev/",
+      ":(){ :|:& };:", "chmod -R 777 /",
+  });
+  for (const auto& pattern : *kBlocked) {
+    if (cmd.find(pattern) != std::string::npos) {
+      return true;
+    }
+  }
+  return false;
+}
