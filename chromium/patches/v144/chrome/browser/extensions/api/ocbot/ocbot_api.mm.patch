+// --- checkPermissions ---
+
+ExtensionFunction::ResponseAction OcbotCheckPermissionsFunction::Run() {
+  base::Value::Dict result;
+  result.Set("supported", true);
+  result.Set("accessibility", AXIsProcessTrusted());
+  if (@available(macOS 11.0, *)) {
+    result.Set("screenRecording", CGPreflightScreenCaptureAccess());
+  } else {
+    result.Set("screenRecording", true);
+  }
+  return RespondNow(WithArguments(std::move(result)));
+}
+
+// --- requestPermission ---
+
+ExtensionFunction::ResponseAction OcbotRequestPermissionFunction::Run() {
+  auto params = api::ocbot::RequestPermission::Params::Create(args());
+  if (!params) {
+    return RespondNow(Error("Invalid parameters"));
+  }
+
+  if (params->permission_type == "accessibility") {
+    NSDictionary* opts = @{(__bridge NSString*)kAXTrustedCheckOptionPrompt : @YES};
+    AXIsProcessTrustedWithOptions((__bridge CFDictionaryRef)opts);
+  } else if (params->permission_type == "screenRecording") {
+    if (@available(macOS 11.0, *)) {
+      CGRequestScreenCaptureAccess();
+    }
+  }
+  return RespondNow(NoArguments());
+}
