+namespace extensions {
+
+namespace {
+
+struct BrowserCandidate {
+  std::string kind;
+  base::FilePath user_data_dir;
+};
+
+std::vector<BrowserCandidate> GetBrowserCandidates() {
+  std::vector<BrowserCandidate> candidates;
+  base::FilePath home_dir;
+  base::PathService::Get(base::DIR_HOME, &home_dir);
+
+#if BUILDFLAG(IS_MAC)
+  base::FilePath app_support =
+      home_dir.Append("Library").Append("Application Support");
+  candidates.push_back(
+      {"chrome", app_support.Append("Google").Append("Chrome")});
+  candidates.push_back(
+      {"brave", app_support.Append("BraveSoftware").Append("Brave-Browser")});
+  candidates.push_back(
+      {"edge", app_support.Append("Microsoft Edge")});
+  candidates.push_back(
+      {"chromium", app_support.Append("Chromium")});
+#elif BUILDFLAG(IS_LINUX)
+  base::FilePath config_dir = home_dir.Append(".config");
+  candidates.push_back({"chrome", config_dir.Append("google-chrome")});
+  candidates.push_back(
+      {"brave",
+       config_dir.Append("BraveSoftware").Append("Brave-Browser")});
+  candidates.push_back({"edge", config_dir.Append("microsoft-edge")});
+  candidates.push_back({"chromium", config_dir.Append("chromium")});
+#elif BUILDFLAG(IS_WIN)
+  base::FilePath local_app_data;
+  base::PathService::Get(base::DIR_LOCAL_APP_DATA, &local_app_data);
+  candidates.push_back(
+      {"chrome",
+       local_app_data.Append(L"Google").Append(L"Chrome").Append(
+           L"User Data")});
+  candidates.push_back(
+      {"brave",
+       local_app_data.Append(L"BraveSoftware")
+           .Append(L"Brave-Browser")
+           .Append(L"User Data")});
+  candidates.push_back(
+      {"edge",
+       local_app_data.Append(L"Microsoft").Append(L"Edge").Append(
+           L"User Data")});
+  candidates.push_back(
+      {"chromium",
+       local_app_data.Append(L"Chromium").Append(L"User Data")});
+#endif
+
+  return candidates;
+}
+
+// Runs on a background thread (MayBlock).
+base::Value::List ScanBrowserProfiles() {
+  base::Value::List results;
+
+  for (const auto& candidate : GetBrowserCandidates()) {
+    if (!base::DirectoryExists(candidate.user_data_dir)) {
+      continue;
+    }
+
+    std::vector<ChromeProfileInfo> profiles =
+        GetChromeProfiles(candidate.user_data_dir);
+    if (profiles.empty()) {
+      continue;
+    }
+
+    base::Value::Dict browser_info;
+    browser_info.Set("kind", candidate.kind);
+    browser_info.Set("userDataDir", candidate.user_data_dir.AsUTF8Unsafe());
+
+    base::Value::List profile_list;
+    for (const auto& profile : profiles) {
+      base::Value::Dict profile_info;
+      profile_info.Set("directory", profile.dir_name);
+      profile_info.Set("name", profile.display_name);
+      profile_info.Set(
+          "path",
+          candidate.user_data_dir
+              .Append(base::FilePath::FromUTF8Unsafe(profile.dir_name))
+              .AsUTF8Unsafe());
+      profile_list.Append(std::move(profile_info));
+    }
+
+    base::Value::Dict entry;
+    entry.Set("browser", std::move(browser_info));
+    entry.Set("profiles", std::move(profile_list));
+    results.Append(std::move(entry));
+  }
+
+  return results;
+}
+
+}  // namespace
+
+ExtensionFunction::ResponseAction OcbotGetBrowserProfilesFunction::Run() {
+  base::ThreadPool::PostTaskAndReplyWithResult(
+      FROM_HERE, {base::MayBlock(), base::TaskPriority::USER_VISIBLE},
+      base::BindOnce(&ScanBrowserProfiles),
+      base::BindOnce(
+          &OcbotGetBrowserProfilesFunction::OnProfilesScanned, this));
+  return RespondLater();
+}
+
+void OcbotGetBrowserProfilesFunction::OnProfilesScanned(
+    base::Value::List results) {
+  Respond(WithArguments(std::move(results)));
+}
+
+ExtensionFunction::ResponseAction OcbotInstallSkillFunction::Run() {
+  std::optional<api::ocbot::InstallSkill::Params> params =
+      api::ocbot::InstallSkill::Params::Create(args());
+  if (!params) {
+    return RespondNow(Error("Invalid arguments"));
+  }
+  const std::string slug = params->slug;
+  if (slug.empty()) {
+    return RespondNow(Error("Missing slug"));
+  }
+  ocbot::InstallSkillBySlug(browser_context(), slug, params->version);
+  return RespondNow(NoArguments());
+}
+
+ExtensionFunction::ResponseAction OcbotUninstallSkillFunction::Run() {
+  std::optional<api::ocbot::UninstallSkill::Params> params =
+      api::ocbot::UninstallSkill::Params::Create(args());
+  if (!params) {
+    return RespondNow(Error("Invalid arguments"));
+  }
+  const std::string slug = params->slug;
+  if (slug.empty()) {
+    return RespondNow(Error("Missing slug"));
+  }
+  ocbot::UninstallSkillBySlug(browser_context(), slug);
+  return RespondNow(NoArguments());
+}
+
+}  // namespace extensions
