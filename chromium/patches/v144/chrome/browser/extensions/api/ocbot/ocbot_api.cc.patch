+ExtensionFunction::ResponseAction OcbotSetProviderFunction::Run() {
+  std::optional<api::ocbot::SetProvider::Params> params =
+      api::ocbot::SetProvider::Params::Create(args());
+  EXTENSION_FUNCTION_VALIDATE(params);
+
+  const api::ocbot::OpenClawProvider& provider = params->provider;
+
+  // Validate inputs.
+  if (!IsValidIdentifier(provider.provider_id)) {
+    return RespondNow(Error("Invalid provider_id."));
+  }
+  if (!IsValidBaseUrl(provider.base_url)) {
+    return RespondNow(Error("Invalid base_url: must be a valid HTTP(S) URL."));
+  }
+  if (!IsValidApiFormat(provider.api_format)) {
+    return RespondNow(Error("Invalid api_format."));
+  }
+  if (provider.api_key.empty() || provider.api_key.size() > 4096) {
+    return RespondNow(Error("Invalid api_key."));
+  }
+  if (!IsValidIdentifier(provider.model_id)) {
+    return RespondNow(Error("Invalid model_id."));
+  }
+  if (provider.model_name.empty() || provider.model_name.size() > 256) {
+    return RespondNow(Error("Invalid model_name."));
+  }
+  if (provider.context_window <= 0 || provider.context_window > 10000000) {
+    return RespondNow(Error("Invalid context_window."));
+  }
+  if (provider.max_tokens <= 0 || provider.max_tokens > 10000000) {
+    return RespondNow(Error("Invalid max_tokens."));
+  }
+
+  // Copy values for the background thread (avoid referencing params after
+  // Run returns).
+  base::ThreadPool::PostTaskAndReplyWithResult(
+      FROM_HERE,
+      {base::MayBlock(), base::TaskPriority::USER_BLOCKING,
+       base::TaskShutdownBehavior::SKIP_ON_SHUTDOWN},
+      base::BindOnce(&DoSetProvider, provider.provider_id, provider.base_url,
+                     provider.api_format, provider.api_key, provider.model_id,
+                     provider.model_name, provider.context_window,
+                     provider.max_tokens),
+      base::BindOnce(&OcbotSetProviderFunction::OnSetProviderDone, this));
+
+  return RespondLater();
+}
+
+void OcbotSetProviderFunction::OnSetProviderDone(bool success) {
+  Respond(WithArguments(success));
+}
+
+ExtensionFunction::ResponseAction OcbotGetConfigFunction::Run() {
+  base::ThreadPool::PostTaskAndReplyWithResult(
+      FROM_HERE,
+      {base::MayBlock(), base::TaskPriority::USER_BLOCKING,
+       base::TaskShutdownBehavior::SKIP_ON_SHUTDOWN},
+      base::BindOnce(&DoGetConfig),
+      base::BindOnce(&OcbotGetConfigFunction::OnGetConfigDone, this));
+
+  return RespondLater();
+}
+
+void OcbotGetConfigFunction::OnGetConfigDone(base::Value::Dict result) {
+  Respond(WithArguments(std::move(result)));
+}
