+// Allowed characters for provider_id and model_id: alphanumeric, dash, dot,
+// underscore. No path separators, whitespace, or control characters.
+bool IsValidIdentifier(const std::string& id) {
+  if (id.empty() || id.size() > 128) {
+    return false;
+  }
+  for (char c : id) {
+    if (!base::IsAsciiAlphaNumeric(c) && c != '-' && c != '_' && c != '.') {
+      return false;
+    }
+  }
+  return true;
+}
+
+bool IsValidBaseUrl(const std::string& url_str) {
+  if (url_str.empty()) {
+    return false;
+  }
+  GURL url(url_str);
+  return url.is_valid() && (url.SchemeIs("https") || url.SchemeIs("http"));
+}
+
+// Allowed api_format values.
+bool IsValidApiFormat(const std::string& format) {
+  return format == "openai-chat" || format == "anthropic-messages" ||
+         format == "google-genai";
+}
+
+// Returns the openclaw config directory path (matches RuntimeManager logic).
+base::FilePath GetConfigDir() {
+#if BUILDFLAG(IS_MAC)
+  base::FilePath home_dir;
+  if (!base::PathService::Get(base::DIR_HOME, &home_dir)) {
+    return base::FilePath();
+  }
+  return home_dir.Append(FILE_PATH_LITERAL("Library"))
+      .Append(FILE_PATH_LITERAL("Application Support"))
+      .Append(FILE_PATH_LITERAL("Ocbot"))
+      .Append(FILE_PATH_LITERAL("openclaw-config"));
+#elif BUILDFLAG(IS_WIN)
+  base::FilePath appdata_dir;
+  if (!base::PathService::Get(base::DIR_ROAMING_APP_DATA, &appdata_dir)) {
+    return base::FilePath();
+  }
+  return appdata_dir.Append(FILE_PATH_LITERAL("Ocbot"))
+      .Append(FILE_PATH_LITERAL("openclaw-config"));
+#else
+  base::FilePath home_dir;
+  if (!base::PathService::Get(base::DIR_HOME, &home_dir)) {
+    return base::FilePath();
+  }
+  return home_dir.Append(FILE_PATH_LITERAL(".config"))
+      .Append(FILE_PATH_LITERAL("ocbot"))
+      .Append(FILE_PATH_LITERAL("openclaw-config"));
+#endif
+}
+
+base::FilePath GetConfigFilePath() {
+  base::FilePath dir = GetConfigDir();
+  if (dir.empty()) {
+    return base::FilePath();
+  }
+  return dir.Append(FILE_PATH_LITERAL("openclaw.json"));
+}
+
+// Read JSON file into a Value::Dict. Returns empty dict on failure.
+base::Value::Dict ReadConfigFile(const base::FilePath& path) {
+  std::string content;
+  if (!base::ReadFileToString(path, &content)) {
+    return base::Value::Dict();
+  }
+  auto parsed = base::JSONReader::ReadDict(content, base::JSON_PARSE_RFC);
+  return parsed ? std::move(*parsed) : base::Value::Dict();
+}
+
+bool WriteConfigFile(const base::FilePath& path,
+                     const base::Value::Dict& dict) {
+  // Ensure parent directory exists.
+  base::FilePath dir = path.DirName();
+  if (!base::CreateDirectory(dir)) {
+    return false;
+  }
+
+  std::string json;
+  if (!base::JSONWriter::WriteWithOptions(
+          dict, base::JSONWriter::OPTIONS_PRETTY_PRINT, &json)) {
+    return false;
+  }
+  return base::WriteFile(path, json);
+}
+
+// Try to send SIGHUP to the gateway process to trigger config reload.
+void SignalGatewayReload() {
+#if BUILDFLAG(IS_POSIX)
+  base::FilePath config_dir = GetConfigDir();
+  if (config_dir.empty()) {
+    return;
+  }
+  base::FilePath pid_file =
+      config_dir.Append(FILE_PATH_LITERAL("gateway.pid"));
+  std::string pid_str;
+  if (!base::ReadFileToString(pid_file, &pid_str)) {
+    return;
+  }
+  int pid = 0;
+  if (!base::StringToInt(base::TrimWhitespaceASCII(pid_str, base::TRIM_ALL),
+                         &pid) ||
+      pid <= 0) {
+    return;
+  }
+  kill(pid, SIGHUP);
+#endif
+}
+
+// Performs the setProvider operation on a background thread.
+bool DoSetProvider(const std::string& provider_id,
+                   const std::string& base_url,
+                   const std::string& api_format,
+                   const std::string& api_key,
+                   const std::string& model_id,
+                   const std::string& model_name,
+                   int context_window,
+                   int max_tokens) {
+  base::FilePath config_path = GetConfigFilePath();
+  if (config_path.empty()) {
+    return false;
+  }
+
+  base::Value::Dict config = ReadConfigFile(config_path);
+
+  // Ensure top-level sections exist.
+  if (!config.FindDict("models")) {
+    config.Set("models", base::Value::Dict());
+  }
+  if (!config.FindDict("auth")) {
+    config.Set("auth", base::Value::Dict());
+  }
+  if (!config.FindDict("agents")) {
+    config.Set("agents", base::Value::Dict());
+  }
+
+  // --- models.providers.<providerId> ---
+  base::Value::Dict* models = config.FindDict("models");
+  if (!models->FindString("mode")) {
+    models->Set("mode", "merge");
+  }
+  if (!models->FindDict("providers")) {
+    models->Set("providers", base::Value::Dict());
+  }
+  base::Value::Dict* providers = models->FindDict("providers");
+
+  base::Value::Dict provider_entry;
+  provider_entry.Set("baseUrl", base_url);
+  provider_entry.Set("api", api_format);
+  provider_entry.Set("authHeader", true);
+
+  base::Value::Dict model_entry;
+  model_entry.Set("id", model_id);
+  model_entry.Set("name", model_name);
+  model_entry.Set("contextWindow", context_window);
+  model_entry.Set("maxTokens", max_tokens);
+
+  base::Value::List model_list;
+  model_list.Append(std::move(model_entry));
+  provider_entry.Set("models", std::move(model_list));
+
+  providers->Set(provider_id, std::move(provider_entry));
+
+  // --- auth.profiles.<providerId>:default ---
+  base::Value::Dict* auth = config.FindDict("auth");
+  if (!auth->FindDict("profiles")) {
+    auth->Set("profiles", base::Value::Dict());
+  }
+  base::Value::Dict* profiles = auth->FindDict("profiles");
+
+  base::Value::Dict auth_profile;
+  auth_profile.Set("provider", provider_id);
+  auth_profile.Set("mode", "api_key");
+  auth_profile.Set("apiKey", api_key);
+
+  std::string profile_key = provider_id + ":default";
+  profiles->Set(profile_key, std::move(auth_profile));
+
+  // --- agents.defaults.model.primary ---
+  base::Value::Dict* agents = config.FindDict("agents");
+  if (!agents->FindDict("defaults")) {
+    agents->Set("defaults", base::Value::Dict());
+  }
+  base::Value::Dict* defaults = agents->FindDict("defaults");
+  if (!defaults->FindDict("model")) {
+    defaults->Set("model", base::Value::Dict());
+  }
+  base::Value::Dict* model = defaults->FindDict("model");
+
+  std::string primary_value = provider_id + "/" + model_id;
+  model->Set("primary", primary_value);
+
+  if (!WriteConfigFile(config_path, config)) {
+    return false;
+  }
+
+  // Signal gateway to reload config.
+  SignalGatewayReload();
+
+  return true;
+}
+
+// Performs the getConfig operation on a background thread.
+base::Value::Dict DoGetConfig() {
+  base::Value::Dict result;
+
+  base::FilePath config_path = GetConfigFilePath();
+  if (config_path.empty()) {
+    result.Set("running", false);
+    return result;
+  }
+
+  base::Value::Dict config = ReadConfigFile(config_path);
+
+  // Extract gateway URL from config.
+  const base::Value::Dict* gateway = config.FindDict("gateway");
+  if (gateway) {
+    const std::string* bind = gateway->FindString("bind");
+    std::optional<int> port = gateway->FindInt("port");
+    if (port) {
+      std::string host = (bind && *bind != "loopback") ? "0.0.0.0"
+                                                        : "127.0.0.1";
+      result.Set("gatewayUrl",
+                 "http://" + host + ":" + base::NumberToString(*port));
+    }
+  }
+
+  // Check if gateway PID file exists as a proxy for running state.
+  base::FilePath config_dir = GetConfigDir();
+  base::FilePath pid_file =
+      config_dir.Append(FILE_PATH_LITERAL("gateway.pid"));
+  result.Set("running", base::PathExists(pid_file));
+
+  return result;
+}
