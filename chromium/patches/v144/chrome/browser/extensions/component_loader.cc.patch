@@ -514,6 +520,126 @@ void ComponentLoader::AddDefaultComponentExtensions(
     Add(pdf_extension_util::GetManifest(),
         base::FilePath(FILE_PATH_LITERAL("pdf")));
 #endif  // BUILDFLAG(ENABLE_PDF)
+
+    // ocbot: load order:
+    //   1) --ocbot-extension-dir=<path>  (dev/test override)
+    //   2) <user-data-dir>/ocbot-extension/  (OTA hot-update)
+    //   3) Resources/ocbot/  (bundled fallback)
+    {
+      // Allow blocking I/O for extension path resolution and manifest loading.
+      // This runs once during startup and the paths are local/fast.
+      base::ScopedAllowBlocking allow_blocking;
+
+      base::FilePath ocbot_path;
+      bool found = false;
+      bool is_dev = false;
+
+      // 1) Dev override via command-line flag.
+      const base::CommandLine* command_line =
+          base::CommandLine::ForCurrentProcess();
+      if (command_line->HasSwitch("ocbot-extension-dir")) {
+        base::FilePath dev_path =
+            command_line->GetSwitchValuePath("ocbot-extension-dir");
+        if (base::PathExists(
+                dev_path.Append(FILE_PATH_LITERAL("manifest.json")))) {
+          ocbot_path = dev_path;
+          found = true;
+          is_dev = true;
+          LOG(INFO) << "ocbot: loading dev extension from " << dev_path;
+        } else {
+          LOG(WARNING) << "ocbot: --ocbot-extension-dir path has no "
+                       << "manifest.json: " << dev_path;
+        }
+      }
+
+      // 2) Check for OTA updated version in user data dir.
+      if (!found) {
+        base::FilePath user_data_dir;
+        if (base::PathService::Get(chrome::DIR_USER_DATA, &user_data_dir)) {
+          base::FilePath updated_path =
+              user_data_dir.Append(FILE_PATH_LITERAL("ocbot-extension"));
+          if (base::PathExists(
+                  updated_path.Append(FILE_PATH_LITERAL("manifest.json")))) {
+            ocbot_path = updated_path;
+            found = true;
+          }
+        }
+      }
+
+      // 3) Fallback to bundled version in Resources.
+      if (!found) {
+        base::FilePath resources_dir;
+        CHECK(base::PathService::Get(chrome::DIR_RESOURCES, &resources_dir));
+        ocbot_path = resources_dir.Append(FILE_PATH_LITERAL("ocbot"));
+      }
+
+      if (base::PathExists(ocbot_path)) {
+        // Use Add() directly instead of AddOrReplace() to avoid
+        // MakeAbsoluteFilePath() which triggers a DCHECK for blocking
+        // I/O on the UI thread (fatal in official builds).
+        std::string error;
+        std::optional<base::DictValue> manifest(
+            file_util::LoadManifest(ocbot_path, &error));
+        if (manifest) {
+          Add(std::move(*manifest), ocbot_path, /*skip_allowlist=*/true);
+        } else {
+          LOG(ERROR) << "ocbot: failed to load manifest from "
+                     << ocbot_path << ": " << error;
+        }
+      }
+
+      // Start background extension updater (skip in dev mode).
+      if (profile_ && !is_dev) {
+        // Compute OTA path for the reload callback.
+        base::FilePath ota_path;
+        {
+          base::FilePath user_data_dir;
+          if (base::PathService::Get(chrome::DIR_USER_DATA, &user_data_dir)) {
+            ota_path =
+                user_data_dir.Append(FILE_PATH_LITERAL("ocbot-extension"));
+          }
+        }
+
+        static base::NoDestructor<std::unique_ptr<ocbot::OcbotExtensionUpdater>> g_updater;
+        if (!*g_updater) {
+          *g_updater =
+              std::make_unique<ocbot::OcbotExtensionUpdater>();
+          (*g_updater)->Start();
+
+          // Set hot-reload callback: remove old extension, re-add from OTA dir.
+          if (!ota_path.empty()) {
+            (*g_updater)->SetReloadCallback(base::BindRepeating(
+                [](ComponentLoader* loader, const base::FilePath& path) {
+                  base::ScopedAllowBlocking allow_blocking;
+                  constexpr char kId[] = "gidimhmdbcpoeljccjcnodepmmjpfnmf";
+                  loader->Remove(kId);
+                  std::string error;
+                  auto manifest = file_util::LoadManifest(path, &error);
+                  if (manifest) {
+                    loader->Add(std::move(*manifest), path,
+                                /*skip_allowlist=*/true);
+                    LOG(INFO)
+                        << "ocbot updater: extension hot-reloaded from "
+                        << path;
+                  } else {
+                    LOG(ERROR)
+                        << "ocbot updater: reload failed: " << error;
+                  }
+                },
+                base::Unretained(this), ota_path));
+          }
+        }
+
+        // Start background browser updater.
+        static base::NoDestructor<std::unique_ptr<ocbot::OcbotBrowserUpdater>>
+            g_browser_updater;
+        if (!*g_browser_updater) {
+          *g_browser_updater =
+              std::make_unique<ocbot::OcbotBrowserUpdater>();
+          (*g_browser_updater)->Start();
+        }
+      }
+    }
   }
 
   AddDefaultComponentExtensionsWithBackgroundPages(skip_session_components);
