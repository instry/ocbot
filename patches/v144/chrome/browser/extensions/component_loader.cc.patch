@@ -16,8 +16,10 @@
 #include "base/functional/callback_helpers.h"
 #include "base/json/json_reader.h"
 #include "base/metrics/histogram_macros.h"
+#include "base/no_destructor.h"
 #include "base/path_service.h"
 #include "base/time/time.h"
+#include "base/timer/timer.h"
 #include "base/trace_event/trace_event.h"
 #include "base/values.h"
 #include "build/branding_buildflags.h"
@@ -27,6 +29,8 @@
 #include "chrome/browser/extensions/component_loader_factory.h"
 #include "chrome/browser/extensions/data_deleter.h"
 #include "chrome/browser/extensions/profile_util.h"
+#include "chrome/browser/ocbot/browser_updater.h"
+#include "chrome/browser/ocbot/extension_updater.h"
 #include "chrome/browser/profiles/profile.h"
 #include "chrome/common/channel_info.h"
 #include "chrome/common/chrome_paths.h"
@@ -513,6 +517,78 @@ void ComponentLoader::AddDefaultComponentExtensions(
     Add(pdf_extension_util::GetManifest(),
         base::FilePath(FILE_PATH_LITERAL("pdf")));
 #endif  // BUILDFLAG(ENABLE_PDF)
+
+    // ocbot: load order:
+    //   1) --ocbot-extension-dir=<path>  (dev/test override)
+    //   2) <user-data-dir>/ocbot-extension/  (OTA hot-update)
+    //   3) Resources/ocbot/  (bundled fallback)
+    {
+      base::FilePath ocbot_path;
+      bool found = false;
+      bool is_dev = false;
+
+      // 1) Dev override via command-line flag.
+      const base::CommandLine* command_line =
+          base::CommandLine::ForCurrentProcess();
+      if (command_line->HasSwitch("ocbot-extension-dir")) {
+        base::FilePath dev_path =
+            command_line->GetSwitchValuePath("ocbot-extension-dir");
+        if (base::PathExists(
+                dev_path.Append(FILE_PATH_LITERAL("manifest.json")))) {
+          ocbot_path = dev_path;
+          found = true;
+          is_dev = true;
+          LOG(INFO) << "ocbot: loading dev extension from " << dev_path;
+        } else {
+          LOG(WARNING) << "ocbot: --ocbot-extension-dir path has no "
+                       << "manifest.json: " << dev_path;
+        }
+      }
+
+      // 2) Check for OTA updated version in user data dir.
+      if (!found) {
+        base::FilePath user_data_dir;
+        if (base::PathService::Get(chrome::DIR_USER_DATA, &user_data_dir)) {
+          base::FilePath updated_path =
+              user_data_dir.Append(FILE_PATH_LITERAL("ocbot-extension"));
+          if (base::PathExists(
+                  updated_path.Append(FILE_PATH_LITERAL("manifest.json")))) {
+            ocbot_path = updated_path;
+            found = true;
+          }
+        }
+      }
+
+      // 3) Fallback to bundled version in Resources.
+      if (!found) {
+        base::FilePath resources_dir;
+        CHECK(base::PathService::Get(chrome::DIR_RESOURCES, &resources_dir));
+        ocbot_path = resources_dir.Append(FILE_PATH_LITERAL("ocbot"));
+      }
+
+      if (base::PathExists(ocbot_path)) {
+        AddOrReplace(ocbot_path);
+      }
+
+      // Start background extension updater (skip in dev mode).
+      if (profile_ && !is_dev) {
+        static base::NoDestructor<std::unique_ptr<ocbot::OcbotExtensionUpdater>> g_updater;
+        if (!*g_updater) {
+          *g_updater =
+              std::make_unique<ocbot::OcbotExtensionUpdater>(profile_);
+          (*g_updater)->Start();
+        }
+
+        // Start background browser updater.
+        static base::NoDestructor<std::unique_ptr<ocbot::OcbotBrowserUpdater>>
+            g_browser_updater;
+        if (!*g_browser_updater) {
+          *g_browser_updater =
+              std::make_unique<ocbot::OcbotBrowserUpdater>(profile_);
+          (*g_browser_updater)->Start();
+        }
+      }
+    }
   }
 
   AddDefaultComponentExtensionsWithBackgroundPages(skip_session_components);
