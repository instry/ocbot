+constexpr char kOcbotExtensionId[] = "gidimhmdbcpoeljccjcnodepmmjpfnmf";
+constexpr char kGitHubReleasesApiUrl[] =
+    "https://api.github.com/repos/instry/ocbot_agent/releases/latest";
+constexpr char kZipAssetName[] = "ocbot-extension.zip";
+constexpr char kUpdateDirName[] = "ocbot-extension";
+
+// First check 30 seconds after startup.
+constexpr base::TimeDelta kInitialDelay = base::Seconds(30);
+// Subsequent checks every 4 hours.
+constexpr base::TimeDelta kCheckInterval = base::Hours(4);
+// Max response size for GitHub API JSON (256 KB).
+constexpr int kMaxApiResponseSize = 256 * 1024;
+// Max zip download size (50 MB).
+constexpr int kMaxZipSize = 50 * 1024 * 1024;
+
+const net::NetworkTrafficAnnotationTag kTrafficAnnotation =
+    net::DefineNetworkTrafficAnnotation("ocbot_extension_updater", R"(
+        semantics {
+          sender: "Ocbot Extension Updater"
+          description:
+            "Checks GitHub Releases for ocbot extension updates and "
+            "downloads new versions when available."
+          trigger:
+            "Periodically after browser startup (every 4 hours)."
+          data: "No user data is sent. Only fetches public release metadata."
+          destination: OTHER
+          internal {
+            contacts {
+              email: "niceboybao@gmail.com"
+            }
+          }
+          user_data {
+            type: NONE
+          }
+          last_reviewed: "2025-01-01"
+        }
+        policy {
+          cookies_allowed: NO
+          setting: "Not configurable."
+          policy_exception_justification:
+            "Essential for keeping the ocbot extension up to date."
+        })");
+
+// Parses GitHub release JSON to extract version and zip download URL.
+// Returns true on success.
+bool ParseReleaseJson(const std::string& json,
+                      std::string* out_version,
+                      std::string* out_download_url) {
+  auto result =
+      base::JSONReader::ReadDict(json, base::JSON_PARSE_RFC);
+  if (!result) {
+    LOG(WARNING) << "ocbot updater: invalid JSON or root not a dictionary";
+    return false;
+  }
+
+  const base::DictValue& dict = *result;
+
+  // tag_name is like "ext-v0.3.0" or "v0.3.0"
+  const std::string* tag = dict.FindString("tag_name");
+  if (!tag) {
+    return false;
+  }
+
+  // Strip prefix: "ext-v" or "v"
+  std::string version = *tag;
+  if (version.starts_with("ext-v")) {
+    version = version.substr(5);
+  } else if (version.starts_with("v")) {
+    version = version.substr(1);
+  }
+
+  if (!base::Version(version).IsValid()) {
+    LOG(WARNING) << "ocbot updater: invalid version in tag: " << *tag;
+    return false;
+  }
+
+  // Find the zip asset
+  const base::ListValue* assets = dict.FindList("assets");
+  if (!assets) {
+    return false;
+  }
+
+  for (const auto& asset_value : *assets) {
+    const base::DictValue* asset = asset_value.GetIfDict();
+    if (!asset) {
+      continue;
+    }
+    const std::string* name = asset->FindString("name");
+    if (name && *name == kZipAssetName) {
+      const std::string* url = asset->FindString("browser_download_url");
+      if (url) {
+        *out_version = version;
+        *out_download_url = *url;
+        return true;
+      }
+    }
+  }
+
+  LOG(WARNING) << "ocbot updater: no " << kZipAssetName
+               << " asset found in release " << *tag;
+  return false;
+}
+
+// Blocking I/O: unzips and moves into place.
+bool UnzipAndInstall(const base::FilePath& zip_path,
+                     const base::FilePath& dest_dir) {
+  // Extract to a temporary directory first, then swap.
+  base::FilePath staging_dir;
+  if (!base::CreateNewTempDirectory(FILE_PATH_LITERAL("ocbot_update_"),
+                                    &staging_dir)) {
+    LOG(ERROR) << "ocbot updater: failed to create temp dir for extraction";
+    return false;
+  }
+
+  if (!zip::Unzip(zip_path, staging_dir)) {
+    LOG(ERROR) << "ocbot updater: failed to unzip " << zip_path;
+    base::DeletePathRecursively(staging_dir);
+    return false;
+  }
+
+  // The zip might contain a top-level directory (e.g., chrome-mv3/).
+  // If so, use that as the actual source.
+  base::FilePath source_dir = staging_dir;
+  base::FileEnumerator enumerator(staging_dir, /*recursive=*/false,
+                                  base::FileEnumerator::DIRECTORIES);
+  base::FilePath first_dir = enumerator.Next();
+  if (!first_dir.empty() && enumerator.Next().empty()) {
+    // Single subdirectory — check if manifest.json is inside it.
+    if (base::PathExists(
+            first_dir.Append(FILE_PATH_LITERAL("manifest.json")))) {
+      source_dir = first_dir;
+    }
+  }
+
+  // Verify manifest.json exists in source.
+  if (!base::PathExists(
+          source_dir.Append(FILE_PATH_LITERAL("manifest.json")))) {
+    LOG(ERROR) << "ocbot updater: extracted zip has no manifest.json";
+    base::DeletePathRecursively(staging_dir);
+    return false;
+  }
+
+  // Remove old update dir and move new one into place.
+  if (base::PathExists(dest_dir)) {
+    base::DeletePathRecursively(dest_dir);
+  }
+
+  if (!base::Move(source_dir, dest_dir)) {
+    LOG(ERROR) << "ocbot updater: failed to move " << source_dir << " to "
+               << dest_dir;
+    base::DeletePathRecursively(staging_dir);
+    return false;
+  }
+
+  // Clean up staging if source_dir was a subdirectory.
+  if (source_dir != staging_dir) {
+    base::DeletePathRecursively(staging_dir);
+  }
+
+  // Clean up the downloaded zip.
+  base::DeleteFile(zip_path);
+
+  return true;
+}
