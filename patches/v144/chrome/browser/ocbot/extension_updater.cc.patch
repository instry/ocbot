+
+OcbotExtensionUpdater::OcbotExtensionUpdater(Profile* profile)
+    : profile_(profile) {}
+
+OcbotExtensionUpdater::~OcbotExtensionUpdater() = default;
+
+void OcbotExtensionUpdater::Start() {
+  DCHECK_CURRENTLY_ON(content::BrowserThread::UI);
+
+  // Post initial delayed check, then repeat.
+  check_timer_.Start(FROM_HERE, kCheckInterval,
+                     base::BindRepeating(&OcbotExtensionUpdater::CheckForUpdate,
+                                         weak_factory_.GetWeakPtr()));
+  // The timer fires after kCheckInterval. For a faster first check,
+  // post a delayed task.
+  content::GetUIThreadTaskRunner({})->PostDelayedTask(
+      FROM_HERE,
+      base::BindOnce(&OcbotExtensionUpdater::CheckForUpdate,
+                     weak_factory_.GetWeakPtr()),
+      kInitialDelay);
+}
+
+void OcbotExtensionUpdater::CheckForUpdate() {
+  DCHECK_CURRENTLY_ON(content::BrowserThread::UI);
+
+  LOG(INFO) << "ocbot updater: checking for extension updates...";
+
+  auto request = std::make_unique<network::ResourceRequest>();
+  request->url = GURL(kGitHubReleasesApiUrl);
+  request->method = "GET";
+  request->load_flags = net::LOAD_DISABLE_CACHE;
+  request->headers.SetHeader("Accept", "application/vnd.github.v3+json");
+  request->credentials_mode = network::mojom::CredentialsMode::kOmit;
+
+  url_loader_ =
+      network::SimpleURLLoader::Create(std::move(request), kTrafficAnnotation);
+  url_loader_->SetRetryOptions(
+      1, network::SimpleURLLoader::RETRY_ON_NETWORK_CHANGE);
+
+  url_loader_->DownloadToString(
+      GetURLLoaderFactory(),
+      base::BindOnce(&OcbotExtensionUpdater::OnReleaseFetched,
+                     weak_factory_.GetWeakPtr()),
+      kMaxApiResponseSize);
+}
+
+void OcbotExtensionUpdater::OnReleaseFetched(
+    std::optional<std::string> response_body) {
+  DCHECK_CURRENTLY_ON(content::BrowserThread::UI);
+
+  if (!response_body) {
+    LOG(WARNING) << "ocbot updater: failed to fetch release info (net error: "
+                 << url_loader_->NetError() << ")";
+    url_loader_.reset();
+    return;
+  }
+
+  url_loader_.reset();
+
+  std::string remote_version;
+  std::string download_url;
+  if (!ParseReleaseJson(*response_body, &remote_version, &download_url)) {
+    LOG(WARNING) << "ocbot updater: failed to parse release JSON";
+    return;
+  }
+
+  std::string current_version = GetCurrentVersion();
+  LOG(INFO) << "ocbot updater: current=" << current_version
+            << " remote=" << remote_version;
+
+  if (current_version.empty()) {
+    // Extension not loaded yet — download anyway.
+    DownloadZip(download_url, remote_version);
+    return;
+  }
+
+  base::Version current(current_version);
+  base::Version remote(remote_version);
+  if (!remote.IsValid() || !current.IsValid()) {
+    LOG(WARNING) << "ocbot updater: invalid version comparison";
+    return;
+  }
+
+  if (remote.CompareTo(current) <= 0) {
+    LOG(INFO) << "ocbot updater: already up to date";
+    return;
+  }
+
+  LOG(INFO) << "ocbot updater: new version available, downloading...";
+  DownloadZip(download_url, remote_version);
+}
+
+void OcbotExtensionUpdater::DownloadZip(const std::string& download_url,
+                                        const std::string& remote_version) {
+  DCHECK_CURRENTLY_ON(content::BrowserThread::UI);
+
+  auto request = std::make_unique<network::ResourceRequest>();
+  request->url = GURL(download_url);
+  request->method = "GET";
+  request->load_flags = net::LOAD_DISABLE_CACHE;
+  request->credentials_mode = network::mojom::CredentialsMode::kOmit;
+
+  url_loader_ =
+      network::SimpleURLLoader::Create(std::move(request), kTrafficAnnotation);
+  url_loader_->SetRetryOptions(
+      2, network::SimpleURLLoader::RETRY_ON_NETWORK_CHANGE);
+
+  // Download to a temporary file.
+  url_loader_->DownloadToTempFile(
+      GetURLLoaderFactory(),
+      base::BindOnce(&OcbotExtensionUpdater::OnZipDownloaded,
+                     weak_factory_.GetWeakPtr(), remote_version),
+      kMaxZipSize);
+}
+
+void OcbotExtensionUpdater::OnZipDownloaded(const std::string& remote_version,
+                                            base::FilePath temp_path) {
+  DCHECK_CURRENTLY_ON(content::BrowserThread::UI);
+
+  if (temp_path.empty()) {
+    LOG(ERROR) << "ocbot updater: zip download failed (net error: "
+               << url_loader_->NetError() << ")";
+    url_loader_.reset();
+    return;
+  }
+
+  url_loader_.reset();
+
+  LOG(INFO) << "ocbot updater: download complete, installing...";
+
+  // Capture values needed on the background thread.
+  base::FilePath dest = GetUpdateDir();
+  if (dest.empty()) {
+    LOG(ERROR) << "ocbot updater: cannot determine update directory";
+    return;
+  }
+
+  // Unzip on a background thread, then reload on UI thread.
+  base::ThreadPool::PostTaskAndReply(
+      FROM_HERE,
+      {base::MayBlock(), base::TaskPriority::USER_VISIBLE,
+       base::TaskShutdownBehavior::SKIP_ON_SHUTDOWN},
+      base::BindOnce(
+          [](base::FilePath zip_path, base::FilePath dest_dir,
+             std::string version) {
+            if (UnzipAndInstall(zip_path, dest_dir)) {
+              LOG(INFO) << "ocbot updater: v" << version << " installed to "
+                        << dest_dir;
+            }
+          },
+          temp_path, dest, remote_version),
+      base::BindOnce(&OcbotExtensionUpdater::ReloadExtension,
+                     weak_factory_.GetWeakPtr()));
+}
+
+void OcbotExtensionUpdater::ReloadExtension() {
+  DCHECK_CURRENTLY_ON(content::BrowserThread::UI);
+
+  base::FilePath update_dir = GetUpdateDir();
+  if (update_dir.empty() ||
+      !base::PathExists(
+          update_dir.Append(FILE_PATH_LITERAL("manifest.json")))) {
+    LOG(ERROR) << "ocbot updater: installation failed, update dir missing";
+    return;
+  }
+
+  // The updated extension will be loaded on next browser restart.
+  // Live-reloading component extensions mid-session is risky, so we
+  // just log that the update is ready.
+  LOG(INFO) << "ocbot updater: update installed to " << update_dir
+            << ". It will take effect on next browser restart.";
+}
+
+std::string OcbotExtensionUpdater::GetCurrentVersion() const {
+  if (!profile_) {
+    return std::string();
+  }
+
+  auto* registry = extensions::ExtensionRegistry::Get(profile_);
+  if (!registry) {
+    return std::string();
+  }
+
+  const extensions::Extension* ext =
+      registry->enabled_extensions().GetByID(kOcbotExtensionId);
+  if (!ext) {
+    return std::string();
+  }
+
+  return ext->version().GetString();
+}
+
+base::FilePath OcbotExtensionUpdater::GetUpdateDir() const {
+  base::FilePath user_data_dir;
+  if (!base::PathService::Get(chrome::DIR_USER_DATA, &user_data_dir)) {
+    return base::FilePath();
+  }
+  return user_data_dir.Append(FILE_PATH_LITERAL(kUpdateDirName));
+}
+
+network::mojom::URLLoaderFactory*
+OcbotExtensionUpdater::GetURLLoaderFactory() {
+  return profile_->GetDefaultStoragePartition()
+      ->GetURLLoaderFactoryForBrowserProcess()
+      .get();
+}
