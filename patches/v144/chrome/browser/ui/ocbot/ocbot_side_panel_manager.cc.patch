+#include "extensions/browser/extension_registry.h"
+
+namespace ocbot {
+
+namespace {
+
+// Returns true if the active tab is showing oc://home (or its extension URL).
+bool IsActiveTabOcHome(BrowserWindowInterface* browser_window) {
+  auto* tab_strip = browser_window->GetTabStripModel();
+  if (!tab_strip) {
+    return false;
+  }
+  auto* web_contents = tab_strip->GetActiveWebContents();
+  if (!web_contents) {
+    return false;
+  }
+  const GURL& url = web_contents->GetLastCommittedURL();
+  if (url.SchemeIs(chrome::kOcScheme)) {
+    return true;
+  }
+  // Also check the extension URL form (chrome-extension://<id>/home.html)
+  if (url.SchemeIs("chrome-extension") &&
+      url.host() == kOcbotExtensionId &&
+      url.path().starts_with("/home.html")) {
+    return true;
+  }
+  return false;
+}
+
+}  // namespace
+
+void ToggleSidePanel(BrowserWindowInterface* browser_window) {
+  if (!browser_window) {
+    return;
+  }
+
+  // ocbot: Don't toggle side panel on oc://home — it already has chat
+  if (IsActiveTabOcHome(browser_window)) {
+    return;
+  }
+
+  auto* profile = browser_window->GetProfile();
+  if (!profile) {
+    return;
+  }
+
+  auto* registry = extensions::ExtensionRegistry::Get(profile);
+  if (!registry) {
+    return;
+  }
+
+  if (!registry->enabled_extensions().GetByID(kOcbotExtensionId)) {
+    return;
+  }
+
+  auto* side_panel_ui = browser_window->GetFeatures().side_panel_ui();
+  if (!side_panel_ui) {
+    return;
+  }
+
+  SidePanelEntry::Key ocbot_key(SidePanelEntry::Id::kExtension,
+                                 kOcbotExtensionId);
+  side_panel_ui->Toggle(ocbot_key, SidePanelOpenTrigger::kToolbarButton);
+}
+
+void OpenSidePanel(BrowserWindowInterface* browser_window) {
+  if (!browser_window) {
+    return;
+  }
+
+  auto* profile = browser_window->GetProfile();
+  if (!profile) {
+    return;
+  }
+
+  auto* registry = extensions::ExtensionRegistry::Get(profile);
+  if (!registry) {
+    return;
+  }
+
+  if (!registry->enabled_extensions().GetByID(kOcbotExtensionId)) {
+    return;
+  }
+
+  auto* side_panel_ui = browser_window->GetFeatures().side_panel_ui();
+  if (!side_panel_ui) {
+    return;
+  }
+
+  SidePanelEntry::Key ocbot_key(SidePanelEntry::Id::kExtension,
+                                 kOcbotExtensionId);
+  side_panel_ui->Show(ocbot_key);
+}
+
+}  // namespace ocbot
