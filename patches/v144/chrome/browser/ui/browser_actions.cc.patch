@@ -1456,6 +1469,33 @@ void BrowserActions::InitializeBrowserActions() {
   }
 #endif  // BUILDFLAG(ENABLE_GLIC)
 
+  // ocbot: Register ocbot side panel action as a first-class action.
+  // This allows ocbot to appear in the toolbar like a built-in feature
+  // rather than an extension.
+  {
+    actions::ActionItem::InvokeActionCallback toggle_ocbot_callback =
+        base::BindRepeating(
+            [](base::WeakPtr<BrowserWindowInterface> bwi,
+               actions::ActionItem* item,
+               actions::ActionInvocationContext context) {
+              if (!bwi) {
+                return;
+              }
+              ocbot::ToggleSidePanel(bwi.get());
+            },
+            bwi->GetWeakPtr());
+
+    root_action_item_->AddChild(
+        actions::ActionItem::Builder(toggle_ocbot_callback)
+            .SetActionId(kActionSidePanelShowOcbot)
+            .SetText(u"Ocbot")
+            .SetTooltipText(u"Ocbot AI Assistant")
+            .SetImage(ocbot::GetOcbotToolbarImage())
+            .SetProperty(actions::kActionItemPinnableKey, true)
+            .SetVisible(true)
+            .Build());
+  }
+
   AddListeners();
 }
 
