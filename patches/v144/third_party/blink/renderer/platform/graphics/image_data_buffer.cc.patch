+bool ImageDataBuffer::MakeWritable() {
+  if (!is_valid_) {
+    return false;
+  }
+  if (pixmap_.writable_addr()) {
+    return true;
+  }
+  const void* src_addr = pixmap_.addr();
+  if (!src_addr) {
+    return false;
+  }
+  size_t size = pixmap_.computeByteSize();
+  if (size == 0 || SkImageInfo::ByteSizeOverflowed(size)) {
+    return false;
+  }
+  sk_sp<SkData> data = SkData::MakeUninitialized(size);
+  if (!data) {
+    return false;
+  }
+  UNSAFE_TODO(memcpy(data->writable_data(), src_addr, size));
+  pixmap_.reset(pixmap_.info(), data->writable_data(), pixmap_.rowBytes());
+  retained_image_ =
+      SkImages::RasterFromData(pixmap_.info(), std::move(data),
+                               pixmap_.rowBytes());
+  return true;
+}
+
+base::span<uint8_t> ImageDataBuffer::MutablePixelData() {
+  if (!is_valid_) {
+    return {};
+  }
+  if (!MakeWritable()) {
+    return {};
+  }
+  void* addr = pixmap_.writable_addr();
+  if (!addr) {
+    return {};
+  }
+  size_t size = pixmap_.computeByteSize();
+  if (size == 0 || SkImageInfo::ByteSizeOverflowed(size)) {
+    return {};
+  }
+  size_t min_row_bytes = pixmap_.info().minRowBytes();
+  if (pixmap_.rowBytes() < min_row_bytes) {
+    return {};
+  }
+  base::CheckedNumeric<size_t> total_bytes = pixmap_.rowBytes();
+  total_bytes *= static_cast<size_t>(pixmap_.height());
+  if (!total_bytes.IsValid() || size < total_bytes.ValueOrDie()) {
+    return {};
+  }
+  return UNSAFE_BUFFERS(base::span<uint8_t>(
+      static_cast<uint8_t*>(addr), size));
+}
